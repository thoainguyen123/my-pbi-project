table Project
	lineageTag: f2906898-a088-4f83-976b-41bd4875bce8

	measure Link_project_ = ```
			
			VAR _link = SELECTEDVALUE(Project[Link_project])
			RETURN
			IF(
			    NOT ISBLANK(_link),
			    "<a href='" & _link & "' target='_blank' " &
			    "style='text-decoration:underline;color:#1a73e8;display:inline-block;'>" &
			    "Link</a>",
			    BLANK()
			)
			
			```
