	partition Project = m
		mode: import
		source = ```
				let
				    // 1. Hàm lấy từng trang (Đã sửa để fix lỗi Dynamic Data Source)
				    GetPage = (PageNumber as number) =>
				        let
				            // URL Gốc (Cố định, không được sửa dòng này)
				            BaseUrl = "https://eoffice.novagroup.vn/api/work/project/gets/",
				            
				            // Các tham số thay đổi (page, limit, token) đưa vào đây
				            Options = [
				                Query = [
				                    access_token = "11869677726889ca3399560771094974",
				                    limit = "100",
				                    page = Number.ToText(PageNumber)
				                ]
				            ],
				            
				            // Gọi Web.Contents với cấu trúc chuẩn: Link gốc + Tham số
				            Source = Json.Document(Web.Contents(BaseUrl, Options)),
				            
				            // Lấy dữ liệu
				            DataList = Source[data]
				        in
				            DataList,
				
				    // 2. Vòng lặp (Giữ nguyên)
				    SourceList = List.Generate(
				        () => [Result = GetPage(1), Page = 1],
				        each not List.IsEmpty([Result]),
				        each [Result = GetPage([Page] + 1), Page = [Page] + 1],
				        each [Result]
				    ),
				
				    // 3. Gom dữ liệu (Giữ nguyên)
				    #"Combined List" = List.Combine(SourceList),
				
				    // 4. Chuyển thành bảng và xử lý (Giữ nguyên code của bạn)
				    #"Converted to Table" = Table.FromList(#"Combined List", Splitter.SplitByNothing(), null, null, ExtraValues.Error),
				    #"Expanded Column1" = Table.ExpandRecordColumn(#"Converted to Table", "Column1", 
				        {"ID", "code", "title", "date_start", "date_end", "status", "num_task", "owner_ids", "desc", "progress", "progress_type", "project_type_id", "tasklist", "tag_ids", "cf1"}, 
				        {"ID", "code", "title", "date_start", "date_end", "status", "num_task", "owner_ids", "desc", "progress", "progress_type", "project_type_id", "tasklist", "tag_ids", "cf1"}),
				    #"Changed Type" = Table.TransformColumnTypes(#"Expanded Column1",{{"progress", Percentage.Type}}),
				    #"Split Column by Delimiter" = Table.SplitColumn(#"Changed Type", "tag_ids", Splitter.SplitTextByDelimiter(",", QuoteStyle.Csv), {"tag_ids.1", "tag_ids.2", "tag_ids.3"}),
				    #"Changed Type1" = Table.TransformColumnTypes(#"Split Column by Delimiter",{{"tag_ids.1", type text}, {"tag_ids.2", type text}, {"tag_ids.3", type text}}),
				    #"Removed Blank Rows" = Table.SelectRows(#"Changed Type1", each not List.IsEmpty(List.RemoveMatchingItems(Record.FieldValues(_), {"", null}))),
				    #"Removed Errors" = Table.RemoveRowsWithErrors(#"Removed Blank Rows", {"code"}),
				    #"Filtered Rows" = Table.SelectRows(#"Removed Errors", each ([code] <> null)),
				    #"Changed Type with Locale" = Table.TransformColumnTypes(#"Filtered Rows", {{"date_start", type date},{"date_end", type date}}, "en-DE")
				in
				    #"Changed Type with Locale"
				```

	annotation PBI_NavigationStepName = Navigation

