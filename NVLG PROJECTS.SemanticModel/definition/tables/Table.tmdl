table Table
	lineageTag: 07bf366b-2b52-49da-904c-957d23b77ab4

	measure 'Số lượng dự án' =
			
			VAR Loc = MAX(DanhMucDauTu[BanDieuHanh])
			VAR x =  CALCULATE(DISTINCTCOUNTNOBLANK(DuAn_By_KhuVuc[TenDuAn]),DuAn_By_KhuVuc[BanDieuHanh] = Loc&& DuAn_By_KhuVuc[isDelete] = 0)
			RETURN IF(x>0,x,0)
		formatString: 0
		lineageTag: 1aa3a24e-5d0d-4c98-ab78-67e40f1ec15c

	measure DrillThrough_Link_Du_An = ```
			
			VAR BaseURL = "https://app.powerbi.com/groups/fecd8a18-81ab-40b5-ba84-705da522e90b/reports/f7e2d494-15f1-419e-a992-3c065fe2ce14/e87daea54d3f16a8c6ab?experience=power-bi&clientSideAuth=0"
			
			// 1. Lấy giá trị từ bảng và cột ĐÃ ĐỔI TÊN trong Power BI Desktop
			// Hãy đảm bảo bạn chọn đúng trường đã đổi tên ở đây
			VAR Gia_Tri_Loc = SELECTEDVALUE('DanhMucDauTu'[BanDieuHanh])
			
			// 2. Xây dựng tham số lọc (URL Filter)
			// Bây giờ URL sẽ rất sạch, không cần %20 nữa
			// Cấu trúc: &filter=TenBang/TenCot eq 'GiaTri'
			
			VAR FilterParam = 
			    "&filter=DanhMucDauTu/BanDieuHanh eq '" 
			    & Gia_Tri_Loc 
			    & "'"
			
			RETURN
			    BaseURL & FilterParam
			```
		lineageTag: 7490c4d5-fcac-45ea-999f-b3f31faa9caa

	measure HTML_DrillThrough_Final = ```
			
			VAR Ten =
			    SELECTEDVALUE ( KhuVuc_Layout[Khu vực] )
			
			-- Tự build link từ Ten, không phụ thuộc vào hàng trong DanhMucDauTu
			VAR BaseURL =
			    "https://app.powerbi.com/groups/fecd8a18-81ab-40b5-ba84-705da522e90b/reports/f7e2d494-15f1-419e-a992-3c065fe2ce14/e87daea54d3f16a8c6ab?experience=power-bi&clientSideAuth=0"
			
			-- Ví dụ filter theo khu vực (tùy bạn encode thế nào)
			VAR Link =
			    BaseURL
			        & "&filter=DanhMucDauTu/BanDieuHanh eq '"
			        & Ten
			        & "'"
			
			RETURN
			IF (
			    ISBLANK ( Ten ),
			    BLANK (),
			    "<a href=""" & Link
			        & """ target=""_blank"" style=""text-decoration:none;"">"
			        & Ten
			        & "</a>"
			)
			
			```
		lineageTag: e201bfbd-b077-4960-ba83-b9dd9235009d

	measure 'Total công việc' =
			
			Var x = CALCULATE(COUNT(Eoffice_TD[title]))
			RETURN IF(x>0,x,"Chưa có công việc trên eoffice")
		formatString: 0
		lineageTag: b5123512-e75f-44b4-8ebc-fd734cae0885

	measure New_Tasks_Current_Month =
			
			VAR _CurrentDate = TODAY()
			RETURN
			    CALCULATE(
			        COUNTROWS('Eoffice_TD'), -- Thay 'TenBangCuaBan' bằng tên bảng thực tế
			        MONTH('Eoffice_TD'[start_plan]) = MONTH(_CurrentDate) &&
			        YEAR('Eoffice_TD'[start_plan]) = YEAR(_CurrentDate)
			    )
		formatString: 0
		lineageTag: 22257015-54a0-47fb-8839-90bd9f5bce76

	measure 'Total công việc hoàn thành' =
			
