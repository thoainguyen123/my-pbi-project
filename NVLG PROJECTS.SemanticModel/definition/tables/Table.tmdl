	measure Measure_Filter_Week = ```
			
			VAR _NgayCanCheck = SELECTEDVALUE(Deep_Lv3[start_plan]) -- Sửa ở đây
			VAR _HomNay = TODAY()
			VAR _Thu2_TuanNay = _HomNay - WEEKDAY(_HomNay, 2) + 1 
			VAR _Thu2_TuanTruoc = _Thu2_TuanNay - 7
			
			RETURN
			    IF(
			        _NgayCanCheck >= _Thu2_TuanTruoc && 
			        _NgayCanCheck <= _HomNay,
			        1, -- Trả về 1 nếu đúng
			        0
			    )
			```
		formatString: 0
		lineageTag: 07637a11-692a-49d8-8123-6512a3586daa

	measure 'Số lượng dự án _ (Khu Vực)' =
			
