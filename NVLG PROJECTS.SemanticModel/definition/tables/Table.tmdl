			        DISTINCTCOUNTNOBLANK(Deep_Lv3[title]), -- Thay 'TenBangCuaBan' bằng tên bảng thực tế
			        MONTH('Deep_Lv3'[start_plan]) = MONTH(_CurrentDate) &&
