	measure 'Final Percent Measure' = ```
			
			VAR _pct3 = AVERAGE(Deep_Lv3[percent])/100
			VAR _pct2 = AVERAGE(Deep_Lv2[percent])/100
			VAR _pct1 = AVERAGE(Deep_Lv1[percent])/100
			RETURN
			 SWITCH( TRUE(),
			        -- Nếu đang xem ở cấp 3: Lấy 3, nếu 3 trống lấy 2, nếu 2 trống lấy 1...
			        ISINSCOPE(Deep_Lv3[title]), COALESCE(_pct3, _pct2, _pct1),
			        
			        -- Nếu đang xem ở cấp 2: Lấy 2, nếu 2 trống lấy 1...
			        ISINSCOPE(Deep_Lv2[title]), COALESCE(_pct2, _pct1),
			        
			       
			        -- Mặc định cho cấp 0 hoặc các cấp cao hơn nữa
			        _pct1
			    )
			```
		formatString: 0%;-0%;0%
		lineageTag: 48cc7af3-358c-4f0f-952f-87c0a13a3b20

	measure 'Final Deadlist Measure' = ```
			
			VAR _pct3 = MAX(Deep_Lv3[deadline_list])
			VAR _pct2 = MAX(Deep_Lv2[deadline_list])
			
			RETURN
			    IF (
			        ISINSCOPE(Deep_Lv2[title]), 
			        COALESCE(_pct3, _pct2), 
			        BLANK()
			    )
			```
		lineageTag: 813ec968-a08e-431a-a406-8b9994394656

	measure 'Final assign_ids Measure' = ```
			
			VAR _pct3 = MAX(Deep_Lv3[assign_ids])
			VAR _pct2 = MAX(Deep_Lv2[assign_ids])
			VAR _pct1 = MAX(Deep_Lv1[assign_ids])
			VAR _pct0 = MAX(Deep_Lv0[assign_ids])
			
			RETURN
			    SWITCH( TRUE(),
			        -- Nếu đang xem ở cấp 3: Lấy 3, nếu 3 trống lấy 2, nếu 2 trống lấy 1...
			        ISINSCOPE(Deep_Lv3[title]), COALESCE(_pct3, _pct2, _pct1, _pct0),
			        
			        -- Nếu đang xem ở cấp 2: Lấy 2, nếu 2 trống lấy 1...
			        ISINSCOPE(Deep_Lv2[title]), COALESCE(_pct2, _pct1, _pct0),
			        
			        -- Nếu đang xem ở cấp 1: Lấy 1, nếu 1 trống lấy 0
			        ISINSCOPE(Deep_Lv1[title]), COALESCE(_pct1, _pct0),
			        
			        -- Mặc định cho cấp 0 hoặc các cấp cao hơn nữa
			        _pct0
			    )
			```
		lineageTag: 0a46db94-b592-45d4-a03b-cc08c7739783

