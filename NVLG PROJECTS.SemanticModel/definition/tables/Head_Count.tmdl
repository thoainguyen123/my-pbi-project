	measure GMD_DT = CALCULATE([SL Tuyen], LEFT(Org[Sort_Phong_Ban],3) = "1.0")
		formatString: 0
		lineageTag: 25583270-7d9c-41dc-98fc-8289a7c0b809

	measure Tổng_Headcount = [SL Tuyen] + [SL Dang Lam Viec]
