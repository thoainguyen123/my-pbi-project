table Head_Count
	lineageTag: 4e982d00-8ac6-4ca1-a783-3bf70576b12d

	measure Dynamic_Title = "Tổng headcount Tháng " & MONTH(TODAY())
		lineageTag: 5713acee-f111-4336-bf06-6b5ebc3ba950

	measure PLP = [PLP_DLV] + [PLP_DT]
		formatString: 0
		lineageTag: 23f73226-70d4-4fbe-93c8-1120e875a174

	measure DMD = [DMD_dLV] + [DMD_DT]
		formatString: 0
		lineageTag: e6d5b3bb-9242-4bc6-8602-4dc982fb04e0

	measure PCD = [PCD_DLV] + [PCD_DT]
		formatString: 0
		lineageTag: 3361190a-7a07-4c30-b8c3-6ab12c17ecb7

	measure PMD = [PMD_DLV] + [PMD_DT]
		formatString: 0
		lineageTag: 99313d09-b03c-4e4e-b251-f4d3f5681679

	measure PM = [PM_DLV] + [PM_DT]
		formatString: 0
		lineageTag: 528ed44e-cc03-43b5-89f8-15210a81bec3

	measure DMD_dLV = CALCULATE([SL Dang Lam Viec], Org[Sort_Phong_Ban] = "4.2 PHÒNG QUẢN LÝ THIẾT KẾ")
		formatString: 0
		lineageTag: f06896fc-f273-466e-9965-2d278b0aa4c1

	measure PLP_DLV = CALCULATE([SL Dang Lam Viec], LEFT(Org[Sort_Phong_Ban],3) = "4.1")
		formatString: 0
		lineageTag: 3bac2cb1-bd0b-457f-b530-afe122f5307d

	measure PCD_DLV = CALCULATE([SL Dang Lam Viec], LEFT(Org[Sort_Phong_Ban],3) = "4.3")
		formatString: 0
		lineageTag: b9e68a99-895f-40a2-b4f9-56eb1f752989

	measure PM_DLV = CALCULATE([SL Dang Lam Viec], LEFT(Org[Sort_Phong_Ban],3) = "4.4")
		formatString: 0
		lineageTag: faa83378-7471-4229-931d-f629802a37c8

	measure PMD_DLV = CALCULATE([SL Dang Lam Viec], LEFT(Org[Sort_Phong_Ban],3) = "4.0")
		formatString: 0
		lineageTag: 23c97e19-cafc-48b7-ab0f-cf01df552453

	measure 'Cac Vi tri Sap' =
			
			SWITCH( TRUE(),
			    -- Đang ở cấp 4 (nếu có): Chỉ hiện của cấp 4
			    ISINSCOPE(Head_Count[Phòng ban]), MAX(Head_Count[Các vị trí sắp ONB & thời gian]),
			
			    -- Mặc định
			    BLANK()
			
			)
		lineageTag: a09c45aa-7e6d-40fd-bf9c-4702e436e37a

	measure 'Ghi chú scope' =
			
			SWITCH( TRUE(),
			    -- Đang ở cấp 4 (nếu có): Chỉ hiện của cấp 4
			    ISINSCOPE(Head_Count[Phòng ban]), MAX(Head_Count[Ghi chú]),
			
			    -- Mặc định
			    BLANK()
			
			)
		lineageTag: f00f518f-9a9b-4b42-b665-a6373bfa6180

	measure PMD_DT = CALCULATE([SL Tuyen], LEFT(Org[Sort_Phong_Ban],3) = "4.0")
		formatString: 0
		lineageTag: d43cfec3-4547-4fc7-b00e-409fb221ca4d

	measure PLP_DT = CALCULATE([SL Tuyen], LEFT(Org[Sort_Phong_Ban],3) = "4.1")
		formatString: 0
		lineageTag: f298c162-fa4c-428e-add3-4a470ae23d10

	measure DMD_DT = CALCULATE([SL Tuyen], Org[Sort_Phong_Ban] = "4.2 PHÒNG QUẢN LÝ THIẾT KẾ")
		formatString: 0
		lineageTag: 5e3f76d5-cbc1-4bfc-8878-4afa92414bb9

	measure PCD_DT = CALCULATE([SL Tuyen], LEFT(Org[Sort_Phong_Ban],3) = "4.3")
		formatString: 0
		lineageTag: 82f2026a-3927-4dcb-9d00-ded77c45a275

	measure PM_DT = CALCULATE([SL Tuyen], LEFT(Org[Sort_Phong_Ban],3) = "4.4")
		formatString: 0
		lineageTag: 6442ac30-4ad7-4b6a-a812-42e18ca940be

	measure GMD = [GMD_DLV] + [GMD_DT]
		formatString: 0
		lineageTag: 7a3f9ee8-f8a1-4c8d-b1ca-366c5e3700eb

	measure GMD_DLV = CALCULATE([SL Dang Lam Viec], LEFT(Org[Sort_Phong_Ban],3) = "1.0")
