	column 'Ten Vung' = ```
			
			TRIM(
			    SUBSTITUTE(
			        [Mã cụm], 
			        "Ban điều hành Dự án Vùng ", 
			        ""
			    )
			)
			```
		lineageTag: 221d446e-849d-4f99-a715-9a0fe15c5ffa
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Phòng ban' =
			
			SWITCH(
			    TRUE(),
			    CONTAINSSTRING(Head_Count[Dự án/Phòng ban], "(PLP"), "4.1 PLP",
			    CONTAINSSTRING(Head_Count[Dự án/Phòng ban], "(DMD"), "4.2 DMD",
			    CONTAINSSTRING(Head_Count[Dự án/Phòng ban], "(PCD"), "4.3 PCD",
			    CONTAINSSTRING(Head_Count[Dự án/Phòng ban], "(PMD"),"4.0 PMD",
			    CONTAINSSTRING(Head_Count[Dự án/Phòng ban], "(PM"), "4.4 PM",
			    CONTAINSSTRING(Head_Count[Dự án/Phòng ban], "(GMD")," GMD",
			
			    BLANK() -- (Tùy chọn) Trả về khoảng trắng nếu không thỏa mãn điều kiện nào ở trên
			)
		lineageTag: 09c97286-895a-4d20-9d11-29e94d7408a0
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

