	column TreeKey =
			IF(
				ISBLANK(Eoffice_TD[code]),
				BLANK(),
				Eoffice_TD[project_code] & "|" & Eoffice_TD[code]
			)
		isHidden
		lineageTag: 3156cd1e-98f3-4c59-86e9-da1f18f2deed
		summarizeBy: none

		annotation SummarizationSetBy = User

	column ParentTreeKey =
			IF(
				ISBLANK(Eoffice_TD[parent_code]),
				BLANK(),
				Eoffice_TD[project_code] & "|" & Eoffice_TD[parent_code]
			)
		isHidden
		lineageTag: da6bb2e3-92d3-4b30-8f25-787d783d53c7
		summarizeBy: none

		annotation SummarizationSetBy = User

	column level_title_1 =
			VAR _level = VALUE(SUBSTITUTE(Eoffice_TD[deep_level], "Cấp ", ""))
			VAR _parent1 = Eoffice_TD[ParentTreeKey]
			VAR _parent2 = MAXX(FILTER(ALL(Eoffice_TD), Eoffice_TD[TreeKey] = _parent1), Eoffice_TD[ParentTreeKey])
			VAR _parent3 = MAXX(FILTER(ALL(Eoffice_TD), Eoffice_TD[TreeKey] = _parent2), Eoffice_TD[ParentTreeKey])
			VAR _parent4 = MAXX(FILTER(ALL(Eoffice_TD), Eoffice_TD[TreeKey] = _parent3), Eoffice_TD[ParentTreeKey])
			VAR _target = SWITCH(_level, 1, Eoffice_TD[TreeKey], 2, _parent1, 3, _parent2, 4, _parent3, 5, _parent4)
			RETURN MAXX(FILTER(ALL(Eoffice_TD), Eoffice_TD[TreeKey] = _target), Eoffice_TD[title])
		lineageTag: 0a1bb6b0-a3b5-406d-bfe0-d24cf6597d21
		summarizeBy: none

		annotation SummarizationSetBy = User

	column level_title_2 =
			VAR _level = VALUE(SUBSTITUTE(Eoffice_TD[deep_level], "Cấp ", ""))
			VAR _parent1 = Eoffice_TD[ParentTreeKey]
			VAR _parent2 = MAXX(FILTER(ALL(Eoffice_TD), Eoffice_TD[TreeKey] = _parent1), Eoffice_TD[ParentTreeKey])
			VAR _parent3 = MAXX(FILTER(ALL(Eoffice_TD), Eoffice_TD[TreeKey] = _parent2), Eoffice_TD[ParentTreeKey])
			VAR _target = SWITCH(_level, 2, Eoffice_TD[TreeKey], 3, _parent1, 4, _parent2, 5, _parent3)
			RETURN MAXX(FILTER(ALL(Eoffice_TD), Eoffice_TD[TreeKey] = _target), Eoffice_TD[title])
		lineageTag: e5517118-6633-4ef3-ae15-4b74c52523d9
		summarizeBy: none

		annotation SummarizationSetBy = User

	column level_title_3 =
			VAR _level = VALUE(SUBSTITUTE(Eoffice_TD[deep_level], "Cấp ", ""))
			VAR _parent1 = Eoffice_TD[ParentTreeKey]
			VAR _parent2 = MAXX(FILTER(ALL(Eoffice_TD), Eoffice_TD[TreeKey] = _parent1), Eoffice_TD[ParentTreeKey])
			VAR _target = SWITCH(_level, 3, Eoffice_TD[TreeKey], 4, _parent1, 5, _parent2)
			RETURN MAXX(FILTER(ALL(Eoffice_TD), Eoffice_TD[TreeKey] = _target), Eoffice_TD[title])
		lineageTag: c64f9d1c-421d-40f0-89f4-01be24a528c6
		summarizeBy: none

		annotation SummarizationSetBy = User

	column level_title_4 =
			VAR _level = VALUE(SUBSTITUTE(Eoffice_TD[deep_level], "Cấp ", ""))
			VAR _parent1 = Eoffice_TD[ParentTreeKey]
			VAR _target = SWITCH(_level, 4, Eoffice_TD[TreeKey], 5, _parent1)
			RETURN MAXX(FILTER(ALL(Eoffice_TD), Eoffice_TD[TreeKey] = _target), Eoffice_TD[title])
		lineageTag: a869fca4-d35f-4d0c-b849-9322d71279fc
		summarizeBy: none

		annotation SummarizationSetBy = User

	column level_title_5 =
			VAR _target = IF(VALUE(SUBSTITUTE(Eoffice_TD[deep_level], "Cấp ", "")) = 5, Eoffice_TD[TreeKey])
			RETURN MAXX(FILTER(ALL(Eoffice_TD), Eoffice_TD[TreeKey] = _target), Eoffice_TD[title])
		lineageTag: 9eb034d7-a2fc-4937-9768-5322caf3eee5
		summarizeBy: none

		annotation SummarizationSetBy = User

	column Legal_Group =
			SWITCH(
				TRUE(),
				LEFT(Eoffice_TD[title], 5) = "4.1.1", "1. Chung",
				LEFT(Eoffice_TD[title], 5) = "4.1.2", "2. Đầu tư",
				LEFT(Eoffice_TD[title], 5) = "4.1.3", "3. Đất đai",
				LEFT(Eoffice_TD[title], 5) = "4.1.4", "4. Quy hoạch",
				LEFT(Eoffice_TD[title], 5) = "4.1.5", "5. Xây dựng",
				LEFT(Eoffice_TD[title], 5) = "4.1.6", "6. Bán hàng",
				BLANK()
			)
		lineageTag: 31064029-fd43-4f4f-a701-ae8a1876d583
		summarizeBy: none
		sortByColumn: Legal_Group_Order

		annotation SummarizationSetBy = User

	column Legal_Group_Order =
			SWITCH(
				TRUE(),
				LEFT(Eoffice_TD[title], 5) = "4.1.1", 1,
				LEFT(Eoffice_TD[title], 5) = "4.1.2", 2,
				LEFT(Eoffice_TD[title], 5) = "4.1.3", 3,
				LEFT(Eoffice_TD[title], 5) = "4.1.4", 4,
				LEFT(Eoffice_TD[title], 5) = "4.1.5", 5,
				LEFT(Eoffice_TD[title], 5) = "4.1.6", 6,
				BLANK()
			)
		isHidden
		lineageTag: 6577f6fb-369c-4ee5-bcbd-e8c11b52d2ef
		summarizeBy: none

		annotation SummarizationSetBy = User

	column Legal_Status =
			VAR _progress = COALESCE(Eoffice_TD[percent], 0)
			RETURN
				SWITCH(
					TRUE(),
					_progress >= 1, "Hoàn thành",
					NOT ISBLANK(Eoffice_TD[end_plan]) && Eoffice_TD[end_plan] < TODAY(), "Quá hạn",
					_progress > 0, "Đang thực hiện",
					"Chưa thực hiện"
				)
		lineageTag: f1187ad1-1439-436d-8105-6135bee1f69e
		summarizeBy: none

		annotation SummarizationSetBy = User

