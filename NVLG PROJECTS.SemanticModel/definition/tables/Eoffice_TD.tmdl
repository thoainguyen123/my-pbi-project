	partition Eoffice_TD = m
		mode: import
		source = ```
				let
				    Source = Excel.Workbook(File.Contents("C:\Python\all_project_task_all_pages.xlsx"), null, true),
				    Sheet1_Sheet = Source{[Item="Data",Kind="Sheet"]}[Data],
				    #"Promoted Headers" = Table.PromoteHeaders(Sheet1_Sheet, [PromoteAllScalars=true]),
				    #"Changed Type" = Table.TransformColumnTypes(#"Promoted Headers",{{"ID", Int64.Type}, {"code", type text}, {"title", type text}, {"status", type text}, {"project_code", type text}, {"project_title", type text}, {"project_id", type text}, {"assign_ids", type text}, {"department_0", type text}, {"department_1", type text}, {"department_2", type text}, {"department_3", type text}, {"department_4", type text}, {"follower_ids", type text}, {"start_plan", type text}, {"end_plan", type text}, {"rating_point", Int64.Type}, {"rating_score", Int64.Type}, {"rating_percent", Int64.Type}, {"rating_desc", type any}, {"is_assign_hour", type text}, {"no_allow_file_on_success", type text}, {"time_plan", type number}, {"time_real", type text}, {"start", type text}, {"end", type text}, {"out_date", Int64.Type}, {"out_date_completed", Int64.Type}, {"priority", type text}, {"date_created", type text}, {"date_updated", type text}, {"desc", type text}, {"department_ids", type text}, {"percent", Percentage.Type}, {"parent_id", type text}, {"parent_title", type text}, {"parent_code", type text}, {"type_id", type text}, {"is_sub", type text}, {"deep_level", type text}, {"method", type text}, {"process_type_id", type any}, {"process_name", type any}, {"owner_ids", type text}, {"owner_id", type text}, {"tasklist_id", type text}, {"parent_group", type text}, {"gettask_ids", type any}, {"progress_type", type text}, {"progress_number", Int64.Type}, {"progress_total", Int64.Type}, {"progress_unit", type any}, {"department_created_id", type text}, {"duration_time", type text}, {"process_node_id", type any}, {"repeat_template_id", Int64.Type}, {"phase_id", type text}, {"progress_note", type text}, {"proportion", type number}, {"created_by_id", type text}, {"process_node_doings", type any}, {"deadline_list", type text}, {"diploma_id", type any}, {"workflow_type", type text}, {"is_overdue_task", type text}, {"date_pause_end", type text}, {"rating_num_fail", Int64.Type}, {"status_after_report", type text}, {"tag_ids", type any}, {"process_step", type any}, {"last_comments", type text}, {"num_file", Int64.Type}}),
				    #"Added Custom" = Table.AddColumn(#"Changed Type", "Custom", each [percent]/100),
				    #"Changed Type1" = Table.TransformColumnTypes(#"Added Custom",{{"Custom", Percentage.Type}}),
				    #"Removed Columns" = Table.RemoveColumns(#"Changed Type1",{"percent"}),
				    #"Renamed Columns" = Table.RenameColumns(#"Removed Columns",{{"Custom", "percent"}}),
				    #"Filtered Rows" = Table.SelectRows(#"Renamed Columns", each ([status] <> "Hủy" and [status] <> "Đóng") and ([code] <> null) and ([deep_level] <> "work.normal.field.deep_level.6" and [deep_level] <> "work.normal.field.deep_level.7" and [deep_level] <> "work.normal.field.deep_level.8")),
				    #"Added Custom1" = Table.AddColumn(
				    #"Filtered Rows",
				    "Custom",
				    each 
				        let
				            // Xác định số khoảng trắng theo cấp độ
				            indent =
				                if [deep_level] = "Cấp 1" then Character.FromNumber(8195)
				                else if [deep_level] = "Cấp 2" then Text.Repeat(Character.FromNumber(8195), 2)
				                else if [deep_level] = "Cấp 3" then Text.Repeat(Character.FromNumber(8195), 3) // <--- Thêm dòng này
				                else if [deep_level] = "Cấp 4" then Text.Repeat(Character.FromNumber(8195), 4) 
				                else "",
				
				            // Áp indent cho dòng đầu
				            firstIndent = indent & [title],
				
				            // Áp indent cho các dòng tiếp theo (nếu có xuống hàng)
				            fullText = Text.Replace(firstIndent, "#(lf)", "#(lf)" & indent)
				        in
				            fullText
				),
				    #"Renamed Columns1" = Table.RenameColumns(#"Added Custom1",{{"Custom", "Des"}}),
				    #"Removed Duplicates" = Table.Distinct(#"Renamed Columns1", {"ID"}),
				    #"Changed Type with Locale" = Table.TransformColumnTypes(#"Removed Duplicates", {{"start_plan", type date}}, "en-DE"),
				    #"Changed Type with Locale1" = Table.TransformColumnTypes(#"Changed Type with Locale", {{"end_plan", type date}}, "en-DE"),
				    #"Replaced Errors" = Table.ReplaceErrorValues(#"Changed Type with Locale1", {{"start_plan", null},{"end_plan", null}}),
				    #"Removed Duplicates1" = Table.Distinct(#"Replaced Errors", {"code"}),
				    #"Added Conditional Column" = Table.AddColumn(#"Removed Duplicates1", "Phong_Nhom", each if Text.StartsWith([title], "4.1") then "4.1 PLP" else if Text.StartsWith([title], "4.2") then "4.2 DMD" else if Text.StartsWith([title], "4.3") then "4.3 PCD" else if Text.StartsWith([title], "4.4") then "4.4 PM" else if Text.StartsWith([title], "9.1") then "9.1 HRC - NHÂN SỰ" else if Text.StartsWith([title], "9.2") then "9.2 FAC" else if Text.StartsWith([title], "9.3") then "9.3 SAC - BÁN HÀNG" else if Text.StartsWith([title], "9.4") then "9.4 MAC - SALE KIT / SỰ KIỆN" else if Text.StartsWith([title], "9.5") then "9.5 PTC - KẾ HOẠCH CƯĐT" else if Text.StartsWith([title], "9.6") then "9.6 QSB - NGÂN SÁCH" else if Text.StartsWith([title], "9.7") then "9.7 SEC - AN NINH" else if Text.StartsWith([title], "9.8") then "9.8 IDD - THIẾT KẾ NỘI BỘ" else if Text.StartsWith([title], "9.9") then "9.9 CSC - BỒI THƯỜNG, GPMB" else if Text.StartsWith([title], "4.0") then "4.0 PMD" else null),
				    #"Added Conditional Column1" = Table.AddColumn(#"Added Conditional Column", "sort_phong", each if Text.StartsWith([title], "9.1") then 1 else if Text.StartsWith([title], "9.2") then 2 else if Text.StartsWith([title], "9.3") then 3 else if Text.StartsWith([title], "9.4") then 4 else if Text.StartsWith([title], "9.5") then 5 else if Text.StartsWith([title], "9.6") then 6 else if Text.StartsWith([title], "9.7") then 7 else if Text.StartsWith([title], "9.8") then 8 else if Text.StartsWith([title], "9.9") then 9 else if Text.StartsWith([title], "4.0") then 10 else if Text.StartsWith([title], "4.1") then 11 else if Text.StartsWith([title], "4.2") then 12 else if Text.StartsWith([title], "4.3") then 13 else if Text.StartsWith([title], "4.4") then 14 else 100),
				    #"Changed Type2" = Table.TransformColumnTypes(#"Added Conditional Column1",{{"sort_phong", Int64.Type}})
				in
				    #"Changed Type2"
				```

