	column Cleaned_Parent_Code_Unique =
			VAR _CurrentCode = Eoffice_TD[code]
			RETURN
				IF(
					ISBLANK(_CurrentCode),
					BLANK(),
					MAXX(
						FILTER(Eoffice_TD, Eoffice_TD[code] = _CurrentCode),
						Eoffice_TD[Cleaned_Parent_Code]
					)
				)
