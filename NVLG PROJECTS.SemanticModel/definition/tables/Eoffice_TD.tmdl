		lineageTag: 368cff85-f72c-47c1-9ff9-9859cd9f0b73
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column Cleaned_Parent_Code =
			VAR _Parent = Eoffice_TD[parent_code]
			VAR _Exists =
				IF(
					ISBLANK(_Parent),
					FALSE,
					NOT ISBLANK(
						MAXX(
							FILTER(Eoffice_TD, Eoffice_TD[code] = _Parent),
							Eoffice_TD[code]
						)
					)
				)
