table Eoffice_TD
	lineageTag: dfa78093-9074-468b-bbd8-1d8f37664f5a

	measure 'PL Tổng hạng mục' =
			CALCULATE(
				DISTINCTCOUNT(Eoffice_TD[code]),
				Eoffice_TD[deep_level] in {"Cấp 1","Cấp 2"},
				NOT ISBLANK(Eoffice_TD[Legal_Group])
			)
		formatString: #,0
		lineageTag: 3eb2d6eb-afaf-4552-bcc6-517406f6b8c7

	measure 'PL Hoàn thành' = CALCULATE([PL Tổng hạng mục], Eoffice_TD[Legal_Status] = "Hoàn thành")
		formatString: #,0
		lineageTag: 961c0607-94cb-4528-8162-81f437a2e149

	measure 'PL Đang thực hiện' = CALCULATE([PL Tổng hạng mục], Eoffice_TD[Legal_Status] = "Đang thực hiện")
		formatString: #,0
		lineageTag: 1c2e1532-104f-4d21-9862-6b4bc486babe

	measure 'PL Chưa thực hiện' = CALCULATE([PL Tổng hạng mục], Eoffice_TD[Legal_Status] = "Chưa thực hiện")
		formatString: #,0
		lineageTag: f7783aaa-e332-407c-b14b-2f87c118e04a

	measure 'PL Quá hạn' = CALCULATE([PL Tổng hạng mục], Eoffice_TD[Legal_Status] = "Quá hạn")
		formatString: #,0
		lineageTag: a1cb8e11-f336-407a-ae9c-2f505d28d21c

	measure 'PL Tỷ lệ hoàn thành' = DIVIDE([PL Hoàn thành], [PL Tổng hạng mục])
		formatString: 0%;-0%;0%
		lineageTag: 1416984d-52f2-4812-8992-ebf5e8bd4eb0

	measure 'PL Tiến độ trung bình' =
			CALCULATE(
				AVERAGE(Eoffice_TD[percent]),
				Eoffice_TD[deep_level] = "Cấp 1"
			)
		formatString: 0%;-0%;0%
		lineageTag: 372e30ce-c21d-41dd-b851-e6e7c4da4602

	measure 'PL Hoàn thành lũy kế' =
			VAR _maxDate = MAX(Eoffice_TD[end_plan])
			RETURN
				CALCULATE(
					[PL Hoàn thành],
					FILTER(ALLSELECTED(Eoffice_TD[end_plan]), Eoffice_TD[end_plan] <= _maxDate)
				)
		formatString: #,0
		lineageTag: 29ffafeb-fbc4-43cf-aba8-853b01c99232

	measure Card_ThoiGian_Ngan = FORMAT(TODAY(), """Ngày"" dd, ""Tháng"" mm , ""Năm"" yyyy")
		lineageTag: 6df3c401-4c3e-4f30-b188-f2683b2dbd39

	measure Dynamic_Value =
			VAR _IsFiltered = ISFILTERED(Phong_Nhom_Dim[Phong_Nhom]) || ISFILTERED(Eoffice_TD[Phong_Nhom])
			VAR _SelectedPhong =
				IF(
					_IsFiltered,
					SELECTEDVALUE(Eoffice_TD[Phong_Nhom]),
					"4.1 PLP"
				)
			VAR _CurrentRowPhong = SELECTEDVALUE(Eoffice_TD[Phong_Nhom])
			VAR _CurrentColPhong = SELECTEDVALUE(MasterData_Columns[Phong_Nhom])
			VAR _ColIndex = SELECTEDVALUE(MasterData_Columns[Col_Index])
			RETURN
				IF(
					NOT(_IsFiltered) && (
						(_CurrentRowPhong <> "4.1 PLP" && NOT(ISBLANK(_CurrentRowPhong))) ||
						(_CurrentColPhong <> "4.1 PLP" && NOT(ISBLANK(_CurrentColPhong)))
					),
					BLANK(),
					SWITCH(
						_SelectedPhong,
						"4.1 PLP",
							SWITCH(
								_ColIndex,
								1, COALESCE(MIN(Eoffice_TD[desc]), "-"),
								2, COALESCE(MIN(Eoffice_TD[cf16]), "-"),
								3, COALESCE(MIN(Eoffice_TD[cf22]), "-"),
								4, COALESCE(FORMAT(MIN(Eoffice_TD[end_plan]), "dd/MM/yyyy"), "-"),
								5, IF(ISBLANK(MIN(Eoffice_TD[Link])), "-", "Link")
							),
						"9.1 HRC - NHÂN SỰ",
							SWITCH(
								_ColIndex,
								1, "100 người",
								2, "85 người",
								3, "15 người",
								4, "Link",
								5, "Đang tuyển dụng"
							),
						"9.2 FAC",
							SWITCH(
								_ColIndex,
								1, "Đã có TBTD",
								2, "Chưa có TBTD",
								3, "Dự kiến có TBTD",
								4, "Link",
								5, "Đang thẩm định"
							),
						"9.3 SAC - BÁN HÀNG",
							SWITCH(
								_ColIndex,
								1, "450 / 500 căn",
								2, "50 căn",
								3, "Q4/2026",
								4, "Link",
								5, "Mở bán đợt 3"
							),
						"9.4 MAC - SALE KIT / SỰ KIỆN",
							SWITCH(
								_ColIndex,
								1, "Đã hoàn thành",
								2, "Kick-off sự kiện",
								3, "15/10/2026",
								4, "Link",
								5, "Chờ duyệt ngân sách"
							),
						"9.5 PTC - KẾ HOẠCH CƯĐT",
							SWITCH(
								_ColIndex,
								1, "Đang đấu thầu",
								2, "Không điều chỉnh",
								3, "30/09/2026",
								4, "Link",
								5, "Đúng tiến độ"
							),
						"9.6 QSB - NGÂN SÁCH",
							SWITCH(
								_ColIndex,
								1, "Đã phê duyệt",
								2, "Tăng 5%",
								3, "15/09/2026",
								4, "Link",
								5, "Dự toán hoàn tất"
							),
						"9.7 SEC - AN NINH",
							SWITCH(
								_ColIndex,
								1, "Đã duyệt phương án",
								2, "Chưa duyệt",
								3, "01/09/2026",
								4, "Link",
								5, "An ninh vòng ngoài"
							),
						"9.8 IDD - THIẾT KẾ NỘI BỘ",
							SWITCH(
								_ColIndex,
								1, "Đã bàn giao",
								2, "Có điều chỉnh",
								3, "20/09/2026",
								4, "Link",
								5, "Phê duyệt thiết kế"
							),
						"9.9 CSC - BỒI THƯỜNG, GPMB",
							SWITCH(
								_ColIndex,
								1, "Có thực hiện",
								2, "Không thực hiện",
								3, "31/12/2026",
								4, "Link",
								5, "Đã đền bù 95%"
							),
						"4.0 PMD - MASTER TIMELINE",
							SWITCH(
								_ColIndex,
								1, "Đang theo dõi",
								2, "Không điều chỉnh",
								3, "30/11/2026",
								4, "Link",
								5, "Đã báo cáo ban giám đốc"
							),
						"4.2 DMD",
							SWITCH(
								_ColIndex,
								1, "Đang thẩm định",
								2, "Không điều chỉnh",
								3, "10/10/2026",
								4, "Link",
								5, "Chờ phê duyệt"
							),
						"4.3 PCD",
							SWITCH(
								_ColIndex,
								1, "85%",
								2, "15/10/2026",
								3, "Link",
								4, "Đang san lấp"
							),
						"4.4 PM",
							SWITCH(
								_ColIndex,
								1, "Đã giao 120/150 căn",
								2, "30 căn",
								3, "25/12/2026",
								4, "Link",
								5, "Bàn giao đợt cuối"
							),
						BLANK()
					)
				)
		lineageTag: c9475112-7ea2-4812-af44-fdf822d3b7dc

	measure Dynamic_Value_URL =
			VAR _IsFiltered = ISFILTERED(Phong_Nhom_Dim[Phong_Nhom]) || ISFILTERED(Eoffice_TD[Phong_Nhom])
			VAR _SelectedPhong =
				IF(
					_IsFiltered,
					SELECTEDVALUE(Eoffice_TD[Phong_Nhom]),
					"4.1 PLP"
				)
			VAR _ColIndex = SELECTEDVALUE(MasterData_Columns[Col_Index])
			RETURN
				SWITCH(
					_SelectedPhong,
					"4.1 PLP",
						IF(_ColIndex = 5, MIN(Eoffice_TD[Link]), BLANK()),
					"9.1 HRC - NHÂN SỰ",
						IF(_ColIndex = 4, "https://link-to-hrc.novagroup.vn", BLANK()),
					"9.2 FAC",
						IF(_ColIndex = 4, "https://link-to-fac.novagroup.vn", BLANK()),
					"9.3 SAC - BÁN HÀNG",
						IF(_ColIndex = 4, "https://link-to-sac.novagroup.vn", BLANK()),
					"9.4 MAC - SALE KIT / SỰ KIỆN",
						IF(_ColIndex = 4, "https://link-to-mac.novagroup.vn", BLANK()),
					"9.5 PTC - KẾ HOẠCH CƯĐT",
						IF(_ColIndex = 4, "https://link-to-ptc.novagroup.vn", BLANK()),
					"9.6 QSB - NGÂN SÁCH",
						IF(_ColIndex = 4, "https://link-to-qsb.novagroup.vn", BLANK()),
					"9.7 SEC - AN NINH",
						IF(_ColIndex = 4, "https://link-to-sec.novagroup.vn", BLANK()),
					"9.8 IDD - THIẾT KẾ NỘI BỘ",
						IF(_ColIndex = 4, "https://link-to-idd.novagroup.vn", BLANK()),
					"9.9 CSC - BỒI THƯỜNG, GPMB",
						IF(_ColIndex = 4, "https://link-to-csc.novagroup.vn", BLANK()),
					"4.0 PMD - MASTER TIMELINE",
						IF(_ColIndex = 4, "https://link-to-pmd.novagroup.vn", BLANK()),
					"4.2 DMD",
						IF(_ColIndex = 4, "https://link-to-dmd.novagroup.vn", BLANK()),
					"4.3 PCD",
						IF(_ColIndex = 3, "https://link-to-pcd.novagroup.vn", BLANK()),
					"4.4 PM",
						IF(_ColIndex = 4, "https://link-to-pm.novagroup.vn", BLANK()),
					BLANK()
				)
		lineageTag: e8a2f3f1-4567-48b2-a1f9-d1f855e90a23
		dataCategory: WebUrl

