	column Ten_Phong_Ban =
			
			SWITCH( TRUE(),
			    LEFT(Eoffice_TD[title], 2) = "7.", "Cung ứng đấu thầu",
			    LEFT(Eoffice_TD[title], 2) = "8.", "Ban Kinh Doanh",
			    LEFT(Eoffice_TD[title], 2) = "9.", "Ban Marketing",
			    LEFT(Eoffice_TD[title], 2) = "6.", "Ban Nhân Sự",
			    LEFT(Eoffice_TD[title], 2) = "4.", "Ban Tài Chính Kế Toán",
			    LEFT(Eoffice_TD[title], 2) = "3.", "Ban Đầu Tư",
			    "" -- Trả về rỗng nếu không thuộc các trường hợp trên
			)
		lineageTag: a94945f5-d484-4f58-a236-7b7047ca6845
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

