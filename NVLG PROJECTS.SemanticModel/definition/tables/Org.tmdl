			    Org[Name OC] = "PHÒNG THỦ TỤC PHÁP LÝ DỰ ÁN", "4.1 PHÒNG THỦ TỤC PHÁP LÝ DỰ ÁN",
			    Org[Name OC] = "PHÒNG QUẢN LÝ THIẾT KẾ", "4.2 PHÒNG QUẢN LÝ THIẾT KẾ",
