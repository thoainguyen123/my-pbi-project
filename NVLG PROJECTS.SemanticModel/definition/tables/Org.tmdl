	measure OrgChart_Support_Dept_Vertical_Scroll = ```
			
			-- ==========================================================================================
			-- PHẦN 1: CẤU HÌNH DỊCH CHUYỂN
			-- ==========================================================================================
			VAR _Offset_X = 3
			VAR _Offset_Y = 0 
			
			-- ==========================================================================================
			-- PHẦN 2: BẢN ĐỒ TOẠ ĐỘ (CỐ ĐỊNH KHOẢNG CÁCH)
			-- ==========================================================================================
			VAR _Layout_Map = DATATABLE (
			    "Ma_OC", STRING, "Left_PX", INTEGER, "Top_PX", INTEGER,
			    {
			        { "FPA",    0,    0   },
			        { "PFD",    0,    185 },
			        { "CMD",    0,    412 },
			        { "ACC",    0,    600 }
			    }
			)
			
			-- ==========================================================================================
			-- PHẦN 3: RENDER
			-- ==========================================================================================
			VAR _All_Cards = 
			    CONCATENATEX(
			        _Layout_Map,
			        VAR _Current_OC = [Ma_OC]
			        VAR _Left       = [Left_PX] + _Offset_X
			        VAR _Top        = [Top_PX] + _Offset_Y
			
			        -- A. Lấy bảng dữ liệu thuộc Mã OC hiện tại
			        VAR _OC_Data = 
			            CALCULATETABLE(
			                Org,
			                Org[Mã OC] = _Current_OC,
			                REMOVEFILTERS(Org)
			            )
			
			        -- B. KIỂM TRA TRẠNG THÁI "KHÔNG TỒN TẠI" CỦA CARD HIỆN TẠI
			        VAR _Is_Card_Disabled = CALCULATE( SUMX( Org, Org[Is_Khong_Ton_Tai] ), Org[Mã OC] = _Current_OC, REMOVEFILTERS(Org) ) > 0
			
			        -- 1. Lấy danh sách Chức danh duy nhất dưới dạng bảng ảo
			        VAR _Titles_In_OC = SUMMARIZE( _OC_Data, Org[Chức danh] )
			        VAR _Has_Data = NOT ISEMPTY(_Titles_In_OC)
			
			        -- 2. Tạo nội dung Text bên trong Card
			        VAR _Content_HTML = 
			            IF( 
			                _Has_Data,
			                CONCATENATEX(
			                    _Titles_In_OC, 
			                    VAR _Role = Org[Chức danh] -- Lấy trực tiếp từ bảng ảo _Titles_In_OC
			                    VAR _Names = 
			                        CALCULATE(
			                            CONCATENATEX(Org, Org[HTML_Nhan_Vien], "", Org[Thứ tự], ASC),
			                            Org[Chức danh] = _Role,
			                            Org[Mã OC] = _Current_OC,
			                            REMOVEFILTERS(Org)
			                        )
			                    
			                    -- Xác định màu chữ dựa vào trạng thái Card
			                    VAR _Text_Color = IF( _Is_Card_Disabled, "#777", "black" )
			                    
			                    RETURN 
			                        "<div style='margin-bottom:3px; width: 100%;'>" & 
			                            -- Tiêu đề Chức danh
			                            "<div style='color:" & _Text_Color & "; font-weight:600; font-size:10px; margin-bottom:1px; line-height:1.0;'>" & 
			                                _Role & 
			                            "</div>" & 
			                            -- Nội dung Nhân viên / Trống / Không tuyển
			                            "<div style='color:" & _Text_Color & "; font-size:10px; line-height:1.0;'>" &
			                                SWITCH(
			                                    TRUE(),
			                                    _Is_Card_Disabled, "<span style='font-style:italic;'>Không tuyển</span>",
			                                    ISBLANK(_Names) || LEN(TRIM(_Names)) = 0, "<span style='font-style:italic; color:#999;'>(Trống)</span>",
			                                    _Names
			                                ) & 
			                            "</div>" & 
			                        "</div>",
			                    "",
			                    -- Sắp xếp bằng EARLIER chuẩn hóa bảo vệ cấu trúc layout
			                    CALCULATE( MIN( Org[Thứ tự] ), Org[Chức danh] = EARLIER(Org[Chức danh]), Org[Mã OC] = _Current_OC, REMOVEFILTERS(Org) ), ASC 
			                ),
			                -- Nếu hoàn toàn không có data dòng nào
			                "<div style='color:" & IF(_Is_Card_Disabled, "#777", "black") & "; font-style:italic; font-size:10px; width:100%; height:100%; display:flex; justify-content:center; align-items:center;'>" & 
			                    IF(_Is_Card_Disabled, "Không tuyển", "(Trống)") & 
			                "</div>"
			            )
			
			        -- 3. Style cho khung chứa (Bôi xám động nhưng giữ nguyên overflow-y để trượt dọc)
			        VAR _Background_Style = 
			            IF( 
			                _Is_Card_Disabled, 
			                "background: #e6e6e6; color: #777; border-radius: 12px; border: 1px solid #ccc;", 
			                "background: transparent; color: black;" 
			            )
			
			        VAR _Card_Style = 
			            "position: absolute; " & 
			            "top: " & _Top & "px; " & 
			            "left: " & _Left & "px; " & 
			            "width: 120px; " &            
			            "height: 120px; " & 
			            "font-size: 10px; " & 
			            _Background_Style & " " & 
			            
			            -- Giữ nguyên cấu trúc hỗ trợ scroll bar từ thiết kế gốc của bạn
			            "overflow-y: auto; " &        
			            "overflow-x: hidden; " &      
			            "text-align: center; " &      
			            "white-space: normal; " &     
			            "word-wrap: break-word; " &   
			            "box-sizing: border-box; " &  
			            "padding: 5px 4px 5px 4px; " & 
			            "display: block; " 
			
			        RETURN 
			            "<div class='scroll-card' style='" & _Card_Style & "'>" & 
			                "<div style='display:flex; flex-direction:column; align-items:center; min-height:100%; justify-content:flex-start;'>" &
			                    _Content_HTML & 
			                "</div>" &
			            "</div>"
			    )
			
			-- CSS TÙY CHỈNH THANH CUỘN (Làm thanh cuộn nhỏ đẹp)
			VAR _Custom_Scrollbar_CSS = 
			    "<style>" &
			    ".scroll-card::-webkit-scrollbar { width: 4px; }" &  
			    ".scroll-card::-webkit-scrollbar-track { background: #f1f1f1; }" & 
			    ".scroll-card::-webkit-scrollbar-thumb { background: #ccc; border-radius: 2px; }" & 
			    ".scroll-card::-webkit-scrollbar-thumb:hover { background: #888; }" & 
			    "</style>"
			
			RETURN
			    -- Canvas Tổng
			    _Custom_Scrollbar_CSS & 
			    "<div style='position:relative; width:100%; height:750px; font-family: Segoe UI;'>" & 
			        _All_Cards & 
			    "</div>"
			```
		lineageTag: fb8fcd3a-c360-47b2-9b3c-96c37df1744c

	measure OrgChart_Support_Dept_Vertical_3 = ```
			
			-- ==========================================================================================
			-- PHẦN 1: CẤU HÌNH DỊCH CHUYỂN TOÀN BỘ CỘT
			-- ==========================================================================================
			VAR _Offset_X = 0 
			VAR _Offset_Y = 0 
			
			-- ==========================================================================================
			-- PHẦN 2: BẢN ĐỒ TOẠ ĐỘ (CHUYỂN SANG DỌC)
			-- ==========================================================================================
			VAR _Layout_Map = DATATABLE (
			    "Ma_OC", STRING, "Left_PX", INTEGER, "Top_PX", INTEGER,
			    {
			        { "OCD",    0,    0   }, 
			        { "HRA",    0,    160 }
			    }
			)
			
			-- ==========================================================================================
			-- PHẦN 3: RENDER
			-- ==========================================================================================
			VAR _All_Cards = 
			    CONCATENATEX(
			        _Layout_Map,
			        VAR _Current_OC = [Ma_OC]
			        VAR _Left       = [Left_PX] + _Offset_X
			        VAR _Top        = [Top_PX] + _Offset_Y
			
			        -- 1. Lấy danh sách Chức danh
			        VAR _Titles_In_OC = 
			            CALCULATETABLE(
			                VALUES(Org[Chức danh]),
			                Org[Mã OC] = _Current_OC,
			                REMOVEFILTERS(Org) 
			            )
			
			        VAR _Has_Data = NOT ISEMPTY(_Titles_In_OC)
			
			        -- 2. Tạo nội dung Text
			        VAR _Content_HTML = 
			            IF( 
			                _Has_Data,
			                CONCATENATEX(
			                    _Titles_In_OC, 
			                    VAR _Role = Org[Chức danh]
			                    VAR _Names = 
			                        CALCULATE(
			                            CONCATENATEX(Org, Org[HTML_Nhan_Vien], "", Org[Thứ tự], ASC),
			                            Org[Chức danh] = _Role,
			                            Org[Mã OC] = _Current_OC
			                        )
			                    RETURN 
			                        IF( 
			                            _Names <> BLANK(),
			                            "<div style='margin-bottom:3px; width: 100%;'>" & 
			                                "<div style='color:black; font-weight:600; font-size:10px; margin-bottom:2px; line-height:1.1;'>" & 
			                                    _Role & 
			                                "</div>" & 
			                                "<div style='color:black; font-size:10px; line-height:1.1;'>" &
			                                    _Names & 
			                                "</div>" &
			                            "</div>",
			                            ""
			                        ),
			                    "",
			                    CALCULATE( MIN( Org[Thứ tự] ) ), ASC 
			                ),
			                -- SỬA TẠI ĐÂY: Thêm flex center và height 100% để chữ nằm chính giữa ô
			                "<div style='color:black; font-style:italic; font-size:10px; width:100%; height:100%; display:flex; justify-content:center; align-items:center;'>(Trống)</div>"
			            )
			
			        -- 3. Style cho khung chứa
			        VAR _Card_Style = 
			            "position: absolute; " & 
			            "top: " & _Top & "px; " & 
			            "left: " & _Left & "px; " & 
			            "width: 120px; " &            -- Đã thêm 'px' vào sau 120
			            "height: 130px; " &           
			            "font-size: 10px; " &          
			            "color: black; " &   
			            
			            -- Căn chỉnh nội dung
			            "text-align: center; " &      
			            "white-space: normal; " &     
			            "word-wrap: break-word; " &   
			            "box-sizing: border-box; " &  
			            "padding: 3px; " &            
			            "display: flex; " &           
			            "flex-direction: column; " &  
			            "align-items: center; " &     
			            "justify-content: flex-start;" 
			
			        RETURN 
			            "<div style='" & _Card_Style & "'>" & 
			                _Content_HTML & 
			            "</div>"
			    )
			
			RETURN
			    -- Canvas Tổng
			    "<div style='position:relative; width:100%; height:300px; font-family: Segoe UI;'>" & 
			        _All_Cards & 
			    "</div>"
			```
