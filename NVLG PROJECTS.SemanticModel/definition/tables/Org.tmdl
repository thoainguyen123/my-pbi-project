			                            _Names <> BLANK(),
			                            "<div style='margin-bottom:3px; width: 100%;'>" & 
			                                -- Tiêu đề: MÀU ĐEN
			                                "<div style='color:black; font-weight:600; font-size:12px; margin-bottom:2px; line-height:1.1;'>" & 
			                                    _Role & 
			                                "</div>" & 
			                                -- Tên nhân viên: MÀU ĐEN
			                                "<div style='color:black; font-size:12px; line-height:1.1;'>" &
			                                    _Names & 
			                                "</div>" &
			                            "</div>",
			                            ""
			                        ),
			                    "",
			                    CALCULATE( MIN( Org[Thứ tự] ) ), ASC 
			                ),
			                -- Chữ trống: MÀU ĐEN (hoặc xám đậm tuỳ bạn, ở đây tôi để đen cho đồng bộ)
			                "<div style='color:black; font-style:italic; font-size:13px'>(Trống)</div>"
			            )
			
			        -- 3. Style cho khung chứa
			        VAR _Card_Style = 
			            "position: absolute; " & 
			            "top: " & _Top & "px; " & 
			            "left: " & _Left & "px; " & 
			            "width: 255px; " &             
			            "height: 150px; " &            
			            "font-size: 12px; " &           
			            "color: black; " &   -- Thiết lập màu đen mặc định
			            
			            -- Căn chỉnh nội dung
			            "text-align: center; " &       
			            "white-space: normal; " &      
			            "word-wrap: break-word; " &    
			            "box-sizing: border-box; " &   
			            "padding: 3px; " &             
			            "display: flex; " &            
			            "flex-direction: column; " &   
			            "align-items: center; " &      
			            "justify-content: flex-start;" 
			
			        RETURN 
			            "<div style='" & _Card_Style & "'>" & 
			                _Content_HTML & 
			            "</div>"
			    )
			
			RETURN
			    -- Canvas Tổng
			    "<div style='position:relative; width:100%; height:100px; font-family: Segoe UI;'>" & 
			        _All_Cards & 
			    "</div>"
			```
