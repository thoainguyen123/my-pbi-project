	measure 'OrgCard HTML Optimize _ 2' = ```
			
			VAR _oc        = SELECTEDVALUE ( Org[Mã OC] )
			VAR _gap       = 6 
			VAR _role_gap  = 4 
			VAR _min_h =
			    SWITCH( TRUE(),
			        CONTAINSSTRING(_oc, "3."), 120,
			        CONTAINSSTRING(_oc, "4."), 210,
			        CONTAINSSTRING(_oc, "2."), 196,
			        CONTAINSSTRING(_oc, "1."), 150,
			        128
			    )
			
			-- Lấy data
			VAR _Data = 
			    CALCULATETABLE (
			        Org,
			        Org[Mã OC] = _oc,
			        REMOVEFILTERS( Org )
			    )
			
			-- Check "Không tồn tại"
			VAR _has_khong_ton_tai = SUMX( _Data, Org[Is_Khong_Ton_Tai] ) > 0
			
			
			-- PHẦN DANH SÁCH NHÂN VIÊN
			VAR _roles =
			    SUMMARIZE (
			        _Data,
			        Org[Chức danh],
			        "RoleOrder", MIN ( Org[Thứ tự] )
			    )
			
			VAR _body_content =
			    CONCATENATEX (
			        _roles,
			        VAR _role = [Chức danh]
			        VAR _names_html = 
			            CONCATENATEX(
			                FILTER( _Data, Org[Chức danh] = _role ),
			                Org[HTML_Nhan_Vien], 
			                "",
			                Org[Thứ tự], ASC
			            )
			
			        RETURN
			            "<div style='margin:0 0 " & _gap & "px 0;padding:0'>" &
			                "<span style='display:block;margin:0 0 " & _role_gap & "px 0;padding:0;font-weight:600;'>" & _role & "</span>" &
			                IF (
			                    LEN ( _names_html ) = 0,
			                    "<span style='display:block;margin:0;padding:0;color:#999;font-style:italic'>(Trống)</span>",
			                    _names_html
			                ) &
			            "</div>",
			        "",
			        [RoleOrder], ASC
			    )
			
			VAR _final_body = _body_content
			
			-- ==========================================================================================
			-- SỬA PHẦN STYLE Ở ĐÂY
			-- ==========================================================================================
			VAR _card_style =
			    "display:block;width:100%;height:100%;box-sizing:border-box;" &
			    "margin:0;line-height:1.2;" & 
			    IF (
			        _has_khong_ton_tai,
			        -- TRƯỜNG HỢP MÀU XÁM: Thêm border-radius vào đây
			        "background:#e6e6e6;color:#777;opacity:1.1;" &
			        "padding:8px 10px;" &
			        "border-radius: 28px;" &  -- <--- Đã thêm bo góc (12px)
			        "min-height:" & _min_h & "px;",
			        
			        -- TRƯỜNG HỢP BÌNH THƯỜNG: Không bo, không nền
			        "padding:0;"
			    )
			
			RETURN
			    "<div style='" & _card_style & "'>" & _final_body & "</div>"
			```
		lineageTag: d646aac0-7b90-40b4-adfa-b4d405cc69c5

	measure OrgChart_Fixed_Offset_Left_Group = ```
			
			-- ==========================================================================================
			-- PHẦN 1: CẤU HÌNH DỊCH CHUYỂN
			-- ==========================================================================================
			VAR _Offset_X = -6  
			
			-- ==========================================================================================
			-- PHẦN 2: BẢN ĐỒ TOẠ ĐỘ GỐC
			-- ==========================================================================================
			VAR _Layout_Map = DATATABLE (
			    "Ma_OC", STRING, "Left_PX", INTEGER, "Top_PX", INTEGER,
			    {
			        { "HRSC",    5,    0 },
			        { "FASC",    140,  0 },
			        { "SSC",     274,  0 },
			        { "MSC",     412,  0 },
			        { "PTSC",    550,  0 },
			        { "QSBS",    688,  0 },
			        { "SESD",    825,  0 },
			        { "IDSD",    962,  0 },
			        { "CSSC",    1098, 0 } 
			    }
			)
			
			-- ==========================================================================================
			-- PHẦN 3: RENDER
			-- ==========================================================================================
			VAR _All_Cards = 
			    CONCATENATEX(
			        _Layout_Map,
			        VAR _Current_OC = [Ma_OC]
			        VAR _Left       = [Left_PX] + _Offset_X
			        VAR _Top        = [Top_PX]
			
			        -- 1. Lấy danh sách Chức danh DUY NHẤT kèm theo Thứ tự nhỏ nhất của chức danh đó
			        VAR _Titles_In_OC = 
			            SUMMARIZE(
			                FILTER(ALL(Org_Chung), Org_Chung[Mã OC] = _Current_OC),
			                Org_Chung[Chức danh],
			                "MinOrder", MIN(Org_Chung[Thứ tự])
			            )
			
			        VAR _Has_Data = NOT ISEMPTY(_Titles_In_OC)
			
			        -- 2. Tạo nội dung Text
			        VAR _Content_HTML = 
			            IF( 
			                _Has_Data,
			                CONCATENATEX(
			                    _Titles_In_OC, 
			                    VAR _Role = [Chức danh]
			                    -- Lấy danh sách nhân viên trong chức danh, lọc bỏ trùng lặp và sắp xếp
			                    VAR _Names = 
			                        CALCULATE(
			                            CONCATENATEX(
			                                SUMMARIZE(Org_Chung, Org_Chung[OCD], Org_Chung[HTML_Nhan_Vien], Org_Chung[Thứ tự]),
			                                Org_Chung[HTML_Nhan_Vien], 
			                                "", 
			                                Org_Chung[Thứ tự], ASC
			                            ),
			                            Org_Chung[Chức danh] = _Role,
			                            Org_Chung[Mã OC] = _Current_OC
			                        )
			                    RETURN 
			                        IF( 
			                            _Names <> BLANK(),
			                            "<div style='margin-bottom:3px; width: 100%;'>" & 
			                                "<div style='color:black; font-weight:600; font-size:10px; margin-bottom:2px; line-height:1.1;'>" & 
			                                    _Role & 
			                                "</div>" & 
			                                "<div style='font-size:10px; line-height:1.1;'>" &
			                                    _Names & 
			                                "</div>" &
			                            "</div>",
			                            ""
			                        ),
			                    "",
			                    [MinOrder], ASC  -- Sắp xếp Chức danh theo Thứ tự đã lấy ở SUMMARIZE
			                ),
			                "<div style='color:#999; font-style:italic; font-size:8px'>(Trống)</div>"
			            )
			
			        -- 3. Style cho khung chứa
			        VAR _Card_Style = 
			            "position: absolute; " & 
			            "top: " & _Top & "px; " & 
			            "left: " & _Left & "px; " & 
			            "width: 133px; " &             
			            "height: 100px; " &             
			            "font-size: 10px; " &           
			            "text-align: center; " &       
			            "white-space: normal; " &      
			            "word-wrap: break-word; " &    
			            "box-sizing: border-box; " &   
			            "padding: 3px; " &             
			            "display: flex; " &            
			            "flex-direction: column; " &   
			            "align-items: center; " &      
			            "justify-content: flex-start;" 
			
			        RETURN 
			            "<div style='" & _Card_Style & "'>" & 
			                _Content_HTML & 
			            "</div>"
			    )
			
			RETURN
			    "<div style='position:relative; width:100%; height:100px; font-family: Segoe UI;'>" & 
			        _All_Cards & 
			    "</div>"
			```
		lineageTag: 7ff940ce-ace0-491b-8e11-6618b7e6e927

	measure 'Org_ChungCard HTML Optimize No HC' = ```
			
			VAR _oc        = SELECTEDVALUE ( Org_Chung[Mã OC] )
			VAR _gap       = 6 
			VAR _role_gap  = 4 
			VAR _min_h =
			    SWITCH( TRUE(),
			        CONTAINSSTRING(_oc, "3."), 120,
			        CONTAINSSTRING(_oc, "4."), 210,
			        CONTAINSSTRING(_oc, "2."), 196,
			        CONTAINSSTRING(_oc, "1."), 150,
			        128
			    )
			
			-- Lấy data
			VAR _Data = 
			    CALCULATETABLE (
			        Org_Chung,
			        Org_Chung[Mã OC] = _oc,
			        REMOVEFILTERS( Org_Chung )
			    )
			
			-- Check "Không tồn tại"
			VAR _has_khong_ton_tai = SUMX( _Data, Org_Chung[Is_Khong_Ton_Tai] ) > 0
			
			-- PHẦN DANH SÁCH NHÂN VIÊN
			VAR _roles =
			    SUMMARIZE (
			        _Data,
			        Org_Chung[Chức danh],
			        "RoleOrder", MIN ( Org_Chung[Thứ tự] )
			    )
			
			VAR _body_content =
			    CONCATENATEX (
			        _roles,
			        VAR _role = [Chức danh]
			        VAR _names_html = 
			            CONCATENATEX(
			                FILTER( _Data, Org_Chung[Chức danh] = _role ),
			                Org_Chung[HTML_Nhan_Vien], 
			                "",
			                Org_Chung[Thứ tự], ASC
			            )
			
			        RETURN
			            "<div style='margin:0 0 " & _gap & "px 0;padding:0'>" &
			                "<span style='display:block;margin:0 0 " & _role_gap & "px 0;padding:0;font-weight:600;'>" & _role & "</span>" &
			                IF (
			                    LEN ( _names_html ) = 0,
			                    "<span style='display:block;margin:0;padding:0;color:#999;font-style:italic'>(Trống)</span>",
			                    _names_html
			                ) &
			            "</div>",
			        "",
			        [RoleOrder], ASC
			    )
			
			-- KIỂM TRA NẾU KHÔNG CÓ DATA THÌ TRẢ VỀ (Trống)
			VAR _final_body = 
			    IF (
			        ISBLANK ( _body_content ) || LEN ( _body_content ) = 0,
			        "<span style='display:block;color:#999;font-style:italic;'>(Trống)</span>",
			        _body_content
			    )
			
			-- ==========================================================================================
			-- SỬA PHẦN STYLE Ở ĐÂY
			-- ==========================================================================================
			VAR _card_style =
			    "display:block;width:100%;height:100%;box-sizing:border-box;" &
			    "margin:0;line-height:1.2;" & 
			    IF (
			        _has_khong_ton_tai,
			        -- TRƯỜNG HỢP MÀU XÁM: Thêm border-radius vào đây
			        "background:#e6e6e6;color:#777;opacity:1.1;" &
			        "padding:8px 10px;" &
			        "border-radius: 28px;" &  -- <--- Đã thêm bo góc (12px)
			        "min-height:" & _min_h & "px;",
			        
			        -- TRƯỜNG HỢP BÌNH THƯỜNG: Không bo, không nền
			        "padding:0;"
			    )
			
			RETURN
			    "<div style='" & _card_style & "'>" & _final_body & "</div>"
			```
		lineageTag: 9397fb5f-b658-4abc-96d5-7243ec1426ee

	measure 'OrgCard HTML Optimize 3' = ```
			
			VAR _oc        = SELECTEDVALUE ( Org[Mã OC] )
			VAR _gap       = 6 
			VAR _role_gap  = 4 
			VAR _min_h =
			    SWITCH( TRUE(),
			        CONTAINSSTRING(_oc, "3."), 120,
			        CONTAINSSTRING(_oc, "4."), 210,
			        CONTAINSSTRING(_oc, "2."), 196,
			        CONTAINSSTRING(_oc, "1."), 150,
			        128
			    )
			
			-- 1. Lấy bảng dữ liệu gốc
			VAR _Data = 
			    CALCULATETABLE (
			        Org,
			        Org[Mã OC] = _oc,
			        REMOVEFILTERS( Org )
			    )
			
			-- Check trạng thái "Không tồn tại"
			VAR _has_khong_ton_tai = SUMX( _Data, Org[Is_Khong_Ton_Tai] ) > 0
			
			-- 2. PHẦN DANH SÁCH CHỨC DANH
			VAR _roles =
			    SUMMARIZE (
			        _Data,
			        Org[Chức danh],
			        "MinRoleOrder", MIN ( Org[Thứ tự] )
			    )
			
			VAR _body_content =
			    CONCATENATEX (
			        _roles,
			        VAR _role = Org[Chức danh]
			        
			        -- 3. LẤY NHÂN VIÊN: Thêm điều kiện lọc tên khác Blank
			        VAR _unique_staff = 
			            SUMMARIZE(
			                FILTER( 
			                    _Data, 
			                    Org[Chức danh] = _role && 
			                    NOT ISBLANK(Org[Tên nhân viên]) &&   -- Lọc bỏ người không có tên
			                    Org[Tên nhân viên] <> ""            -- Lọc bỏ chuỗi rỗng nếu có
			                ),
			                Org[Tên nhân viên],
			                "StaffHTML", FIRSTNONBLANK(Org[HTML_Nhan_Vien], 1),
			                "StaffOrder", MIN(Org[Thứ tự])
			            )
			
			        VAR _names_html = 
			            CONCATENATEX(
			                _unique_staff,
			                [StaffHTML], 
			                "",
			                [StaffOrder], ASC
			            )
			
			        RETURN
			            -- Chỉ hiển thị Chức danh nếu có nhân viên bên trong (đã lọc blank)
			            IF ( 
			                NOT ISBLANK(_names_html) && LEN(_names_html) > 0,
			                "<div style='margin:0 0 " & _gap & "px 0;padding:0'>" &
			                    "<span style='display:block;margin:0 0 " & _role_gap & "px 0;padding:0;font-weight:600;'>" & _role & "</span>" &
			                    _names_html &
			                "</div>",
			                ""
			            ),
			        "",
			        [MinRoleOrder], ASC
			    )
			
			-- ==========================================================================================
			-- STYLE VÀ RETURN
			-- ==========================================================================================
			VAR _card_style =
			    "display:block;width:100%;height:100%;box-sizing:border-box;" &
			    "margin:0;line-height:1.2;" & 
			    IF (
			        _has_khong_ton_tai,
			        "background:#e6e6e6;color:#777;padding:8px 10px;border-radius: 28px;min-height:" & _min_h & "px;",
			        "padding:0;"
			    )
			
			RETURN
			    "<div style='" & _card_style & "'>" & _body_content & "</div>"
			```
		lineageTag: efab438a-e07d-49b9-bec0-05a18c6f77e5

