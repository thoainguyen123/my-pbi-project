	column Is_Khong_Ton_Tai =
			
			IF ( LOWER ( TRIM ( Org[Ghi chú] ) ) = "không tồn tại"|| CONTAINSSTRING(LOWER(Org[Ghi chú]),"không hoạt động") , 1, 0 )
		formatString: 0
		lineageTag: b228af63-e719-402b-a613-a9bdba9effca
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column HTML_Nhan_Vien =
			
			VAR _name_gap = 3
			VAR _ten = TRIM ( Org[Tên nhân viên] )
			VAR _gc  = TRIM ( Org[Ghi chú] )
			VAR _gc_fmt = IF ( LEN ( _gc ) > 1, " " & _gc, "" )
			VAR _line   = TRIM ( _ten  & _gc_fmt )
			RETURN
			    "<span style='display:block;margin:0 0 " & _name_gap & "px 0;padding:0'>" &
			        IF ( _line = "", "(Trống)", _line ) &
			    "</span>"
