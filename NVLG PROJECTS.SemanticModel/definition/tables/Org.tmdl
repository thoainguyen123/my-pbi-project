	measure OrgChart_PM_Dept_Black_2 = ```
			
			-- ==========================================================================================
			-- PHẦN 1: CẤU HÌNH DỊCH CHUYỂN
			-- ==========================================================================================
			VAR _Offset_X = -6  -- Số âm là dịch sang TRÁI
			
			-- ==========================================================================================
			-- PHẦN 2: BẢN ĐỒ TOẠ ĐỘ (Support Dept)
			-- ==========================================================================================
			VAR _Layout_Map = DATATABLE (
			    "Ma_OC", STRING, "Left_PX", INTEGER, "Top_PX", INTEGER,
			    {
			        { "PLP",   45,    0 },
			        { "DMD",    395,  0 },
			        { "PCD",    980,  0 },
			        { "PM",    2580,  0 }
			    }
			)
			
			-- ==========================================================================================
			-- PHẦN 3: RENDER
			-- ==========================================================================================
			VAR _All_Cards = 
			    CONCATENATEX(
			        _Layout_Map,
			        VAR _Current_OC = [Ma_OC]
			        VAR _Left       = [Left_PX] + _Offset_X
			        VAR _Top        = [Top_PX]
			
			        -- 1. Lấy danh sách Chức danh
			        VAR _Titles_In_OC = 
			            CALCULATETABLE(
			                VALUES(Org[Chức danh]),
			                Org[Mã OC] = _Current_OC,
			                REMOVEFILTERS(Org) 
			            )
			
			        VAR _Has_Data = NOT ISEMPTY(_Titles_In_OC)
			
			        -- 2. Tạo nội dung Text
			        VAR _Content_HTML = 
			            IF( 
			                _Has_Data,
			                CONCATENATEX(
			                    _Titles_In_OC, 
			                    VAR _Role = Org[Chức danh]
			                    VAR _Names = 
			                        CALCULATE(
			                            CONCATENATEX(Org, Org[HTML_Nhan_Vien], "", Org[Thứ tự], ASC),
			                            Org[Chức danh] = _Role,
			                            Org[Mã OC] = _Current_OC
			                        )
			                    RETURN 
			                        IF( 
			                            _Names <> BLANK(),
			                            "<div style='margin-bottom:3px; width: 100%;'>" & 
			                                -- Tiêu đề: MÀU ĐEN
			                                "<div style='color:black; font-weight:600; font-size:14px; margin-bottom:2px; line-height:1.1;'>" & 
			                                    _Role & 
			                                "</div>" & 
			                                -- Tên nhân viên: MÀU ĐEN
			                                "<div style='color:black; font-size:14px; line-height:1.1;'>" &
			                                    _Names & 
			                                "</div>" &
			                            "</div>",
			                            ""
			                        ),
			                    "",
			                    CALCULATE( MIN( Org[Thứ tự] ) ), ASC 
			                ),
			                -- Chữ trống: MÀU ĐEN (hoặc xám đậm tuỳ bạn, ở đây tôi để đen cho đồng bộ)
			                "<div style='color:black; font-style:italic; font-size:14px'>(Trống)</div>"
			            )
			
			        -- 3. Style cho khung chứa
			        VAR _Card_Style = 
			            "position: absolute; " & 
			            "top: " & _Top & "px; " & 
			            "left: " & _Left & "px; " & 
			            "width: 260px; " &             
			            "height: 85px; " &            
			            "font-size: 14px; " &           
			            "color: black; " &   -- Thiết lập màu đen mặc định
			            
			            -- Căn chỉnh nội dung
			            "text-align: center; " &       
			            "white-space: normal; " &      
			            "word-wrap: break-word; " &    
			            "box-sizing: border-box; " &   
			            "padding: 3px; " &             
			            "display: flex; " &            
			            "flex-direction: column; " &   
			            "align-items: center; " &      
			            "justify-content: flex-start;" 
			
			        RETURN 
			            "<div style='" & _Card_Style & "'>" & 
			                _Content_HTML & 
			            "</div>"
			    )
			
			RETURN
			    -- Canvas Tổng
			    "<div style='position:relative; width:100%; height:85px; font-family: Segoe UI;'>" & 
			        _All_Cards & 
			    "</div>"
			```
