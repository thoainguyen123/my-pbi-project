table Org
	lineageTag: c0bc12c9-4914-461a-b0cd-04b1c421db1e

	measure 'OrgCard HTML Optimize' = ```
			
			VAR _oc        = SELECTEDVALUE ( Org[Mã OC] )
			VAR _gap       = 6 
			VAR _role_gap  = 4 
			VAR _min_h =
			    SWITCH( TRUE(),
			        CONTAINSSTRING(_oc, "3."), 120,
			        CONTAINSSTRING(_oc, "4."), 210,
			        CONTAINSSTRING(_oc, "2."), 196,
			        CONTAINSSTRING(_oc, "1."), 150,
			        CONTAINSSTRING(_oc, "PLP2"), 185,
			        128
			    )
			
			-- 1. Lấy data gốc
			VAR _RawData = 
			    CALCULATETABLE (
			        Org,
			        Org[Mã OC] = _oc,
			        REMOVEFILTERS( Org )
			    )
			
			-- 2. TẠO BẢNG HIỂN THỊ (Loại trùng nội dung ngay từ đầu)
			VAR _DisplayData = 
			    SUMMARIZE(
			        _RawData,
			        Org[Chức danh],
			        Org[HTML_Nhan_Vien]
			    )
			
			-- 3. ĐẾM ĐỊNH BIÊN
			VAR _Rows_Valid = 
			    FILTER( 
			        _RawData, 
			        Org[Ghi chú] <> "không tồn tại" && 
			        Org[Ghi chú] <> "không hoạt động" 
			    )
			VAR _Total_Plan = COUNTROWS( _Rows_Valid ) + 0
			VAR _Total_Current = COUNTX( _Rows_Valid, Org[Tên nhân viên] ) + 0
			
			VAR _Header_Dinh_Bien = 
			    IF(
			        _Total_Plan > 0, 
			        "<div style='margin-bottom:" & _gap & "px; padding-bottom:4px; border-bottom:1px dashed #ccc; font-size: 11px;'>" & 
			            "<span style='color:#666;'>Định biên: </span>" & 
			            "<span style='font-weight:bold; color:#005c99;'>" & _Total_Current & "/" & _Total_Plan & "</span>" &
			        "</div>",
			        ""
			    )
			
			-- Xác định thẻ có chứa trạng thái "không tồn tại" hay không
			VAR _has_khong_ton_tai = SUMX( _RawData, Org[Is_Khong_Ton_Tai] ) > 0
			
			-- 4. PHẦN DANH SÁCH NHÂN VIÊN
			VAR _roles =
			    SUMMARIZE (
			        _RawData,
			        Org[Chức danh],
			        "RoleOrder", MIN ( Org[Thứ tự] )
			    )
			
			VAR _body_content =
			    CONCATENATEX (
			        _roles,
			        VAR _role = [Chức danh]
			        
			        VAR _names_html = 
			            CONCATENATEX(
			                FILTER( _DisplayData, Org[Chức danh] = _role ),
			                Org[HTML_Nhan_Vien], 
			                ""
			            )
			
			        RETURN
			            "<div style='margin:0 0 " & _gap & "px 0;padding:0'>" &
			                "<span style='display:block;margin:0 0 " & _role_gap & "px 0;padding:0;font-weight:600;'>" & _role & "</span>" &
			                IF (
			                    _has_khong_ton_tai,
			                    -- Nếu có trạng thái không tồn tại thì ép hiển thị Không tuyển
			                    "<span style='display:block;margin:0;padding:0;color:#777;font-style:italic'>Không tuyển</span>",
			                    -- Nếu bình thường thì chạy logic cũ
			                    IF (
			                        LEN ( _names_html ) = 0,
			                        "<span style='display:block;margin:0;padding:0;color:#999;font-style:italic'>(Trống)</span>",
			                        _names_html
			                    )
			                ) &
			            "</div>",
			        "",
			        [RoleOrder], ASC
			    )
			
			VAR _final_body = _Header_Dinh_Bien & _body_content
			
			-- 5. STYLE CARD
			VAR _card_style =
			    "display:block;width:100%;height:100%;box-sizing:border-box;" &
			    "margin:0;line-height:1.2;" & 
			    IF (
			        _has_khong_ton_tai,
			        "background:#e6e6e6;color:#777;opacity:1.1;" &
			        "padding:8px 10px;" &
			        "border-radius: 28px;" & 
			        "min-height:" & _min_h & "px;",
			        "padding:0;"
			    )
			
			RETURN
			    "<div style='" & _card_style & "'>" & _final_body & "</div>"
			```
		lineageTag: 113b0597-10dc-4cfc-b0ff-6ab5adb38cc7

	measure 'TCKT link' = ```
			
			VAR Link = "https://app.powerbi.com/groups/1bc73c10-682f-4ec0-b653-542ec85e77b5/reports/69ff69d4-9853-4c6f-b0f5-0e63267222cf/8ee8adb13c4b5128e0e8?experience=power-bi&clientSideAuth=0"
			VAR Ten  = Org[OrgCard HTML Optimize]
			RETURN
			    "<a href=""" 
			        & Link 
			        & """ target=""_blank"" style=""text-decoration:none;"">"
			        & Ten
			        & "</a>"
			
			```
		lineageTag: 113fb80a-5e04-4237-b11c-683de7c2afa0

	measure OC_IsNotExist = ```
			
			VAR _oc = SELECTEDVALUE(Org[Mã OC])
			RETURN
			IF(
			    CALCULATE(
			        COUNTROWS(Org),
			        FILTER(
			            ALL(Org),
			            Org[Mã OC] = _oc &&
			            LOWER(TRIM(COALESCE(Org[Ghi chú],""))) = "không tồn tại"
			        )
			    ) > 0,
			    1, 0
			)
			
			```
		formatString: 0
		lineageTag: 464ca93a-93f0-467e-ada6-38efea665247

	measure 'Link_dự án' = ```
			
			VAR _link = MAX(Eoffice_TD[Link])
			RETURN
			IF(
			    NOT ISBLANK(_link),
			    "<a href='" & _link & "' target='_blank' " &
			    "style='text-decoration:underline;color:#1a73e8;display:inline-block;'>" &
			    "Link</a>",
			    BLANK()
			)
			
			```
		lineageTag: 12be6e6a-9529-49e4-be15-df852db1821c

	measure Org_ChungChart_Fixed_Offset_Left = ```
			
			-- ==========================================================================================
			-- PHẦN 1: CẤU HÌNH DỊCH CHUYỂN (Chỉnh số này để nhích qua lại)
			-- ==========================================================================================
			VAR _Offset_X = -6  -- Số âm là dịch sang TRÁI, số dương là dịch sang PHẢI
			
			-- ==========================================================================================
			-- PHẦN 2: BẢN ĐỒ TOẠ ĐỘ GỐC (Giữ nguyên như cũ)
			-- ==========================================================================================
			VAR _Layout_Map = DATATABLE (
			    "Ma_OC", STRING, "Left_PX", INTEGER, "Top_PX", INTEGER,
			    {
			        { "HRC",    5,    0 },
			        { "FAC",    140,  0 },
			        { "SAC",    276,  0 },
			        { "MAC",    414,  0 },
			        { "PTC",    550,  0 },
			        { "QSB",    688,  0 },
			        { "SED",    824,  0 },
			        { "IDD",    962,  0 },
			        { "CSC",    1100, 0 } 
			    }
			)
			
			-- ==========================================================================================
			-- PHẦN 3: RENDER
			-- ==========================================================================================
			VAR _All_Cards = 
			    CONCATENATEX(
			        _Layout_Map,
			        VAR _Current_OC = [Ma_OC]
			        -- Áp dụng độ lệch toạ độ tại đây
			        VAR _Left       = [Left_PX] + _Offset_X
			        VAR _Top        = [Top_PX]
			
			        -- 1. Lấy danh sách Chức danh
			        VAR _Titles_In_OC = 
			            CALCULATETABLE(
			                VALUES(Org_Chung[Chức danh]),
			                Org_Chung[Mã OC] = _Current_OC,
			                REMOVEFILTERS(Org_Chung) 
			            )
			
			        VAR _Has_Data = NOT ISEMPTY(_Titles_In_OC)
			
			        -- 2. Tạo nội dung Text
			        VAR _Content_HTML = 
			            IF( 
			                _Has_Data,
			                CONCATENATEX(
			                    _Titles_In_OC, 
			                    VAR _Role = Org_Chung[Chức danh]
			                    VAR _Names = 
			                        CALCULATE(
			                            CONCATENATEX(Org_Chung, Org_Chung[HTML_Nhan_Vien], "", Org_Chung[Thứ tự], ASC),
			                            Org_Chung[Chức danh] = _Role,
			                            Org_Chung[Mã OC] = _Current_OC
			                        )
			                    RETURN 
			                        IF( 
			                            _Names <> BLANK(),
			                            "<div style='margin-bottom:3px; width: 100%;'>" & 
			                                -- Tiêu đề: Đen, Đậm, Size 8px
			                                "<div style='color:black; font-weight:600; font-size:10px; margin-bottom:2px; line-height:1.1;'>" & 
			                                    _Role & 
			                                "</div>" & 
			                                -- Tên nhân viên
			                                "<div style='font-size:10px; line-height:1.1;'>" &
			                                    _Names & 
			                                "</div>" &
			                            "</div>",
			                            ""
			                        ),
			                    "",
			                    CALCULATE( MIN( Org_Chung[Thứ tự] ) ), ASC 
			                ),
			                "<div style='color:#999; font-style:italic; font-size:8px'>(Trống)</div>"
			            )
			
			        -- 3. Style cho khung chứa
			        VAR _Card_Style = 
			            "position: absolute; " & 
			            "top: " & _Top & "px; " & 
			            "left: " & _Left & "px; " & 
			            "width: 133px; " &             
			            "height: 100px; " &            
			            "font-size: 10px; " &           
			            
			            -- Căn chỉnh nội dung
			            "text-align: center; " &       
			            "white-space: normal; " &      
			            "word-wrap: break-word; " &    
			            "box-sizing: border-box; " &   
			            "padding: 3px; " &             
			            "display: flex; " &            
			            "flex-direction: column; " &   
			            "align-items: center; " &      
			            "justify-content: flex-start;" 
			
			        RETURN 
			            "<div style='" & _Card_Style & "'>" & 
			                _Content_HTML & 
			            "</div>"
			    )
			
			RETURN
			    -- Canvas Tổng
			    "<div style='position:relative; width:100%; height:100px; font-family: Segoe UI;'>" & 
			        _All_Cards & 
			    "</div>"
			```
		lineageTag: 87c29d9b-3f9d-4384-968b-250950e29171

	measure OrgChart_Support_Dept_All_White = ```
			
			-- ==========================================================================================
			-- PHẦN 1: CẤU HÌNH DỊCH CHUYỂN
			-- ==========================================================================================
			VAR _Offset_X = -5 
			
			-- ==========================================================================================
			-- PHẦN 2: BẢN ĐỒ TOẠ ĐỘ GỐC
			-- ==========================================================================================
			VAR _Layout_Map = DATATABLE (
			    "Ma_OC", STRING, "Left_PX", INTEGER, "Top_PX", INTEGER,
			    {
			        { "INC",    0,    0 },
			        { "LEC",    129,  0 },
			        { "ITD",    261,  0 },
			        { "PSMD",   393,  0 },
			        { "CQI",    522,  0 },
			        { "PRD",    655,  0 },
			        { "RPC",    788,  0 }
			    }
			)
			
			-- ==========================================================================================
			-- PHẦN 3: RENDER
			-- ==========================================================================================
			VAR _All_Cards = 
			    CONCATENATEX(
			        _Layout_Map,
			        VAR _Current_OC = [Ma_OC]
			        VAR _Left       = [Left_PX] + _Offset_X
			        VAR _Top        = [Top_PX]
			
			        -- 1. Lấy danh sách Chức danh
			        VAR _Titles_In_OC = 
			            CALCULATETABLE(
			                VALUES(Org[Chức danh]),
			                Org[Mã OC] = _Current_OC,
			                REMOVEFILTERS(Org) 
			            )
			
			        VAR _Has_Data = NOT ISEMPTY(_Titles_In_OC)
			
			        -- 2. Tạo nội dung Text
			        VAR _Content_HTML = 
			            IF( 
			                _Has_Data,
			                CONCATENATEX(
			                    _Titles_In_OC, 
			                    VAR _Role = Org[Chức danh]
			                    VAR _Names = 
			                        CALCULATE(
			                            CONCATENATEX(Org, Org[HTML_Nhan_Vien], "", Org[Thứ tự], ASC),
			                            Org[Chức danh] = _Role,
			                            Org[Mã OC] = _Current_OC
			                        )
			                    RETURN 
			                        IF( 
			                            _Names <> BLANK(),
			                            "<div style='margin-bottom:3px; width: 100%;'>" & 
			                                -- Tiêu đề: MÀU TRẮNG
			                                "<div style='color:white; font-weight:bold; font-size:9px; margin-bottom:2px; line-height:1.1;'>" & 
			                                    _Role & 
			                                "</div>" & 
			                                -- Tên nhân viên: MÀU TRẮNG
			                                "<div style='color:white; font-size:9px; line-height:1.1;'>" &
			                                    _Names & 
			                                "</div>" &
			                            "</div>",
			                            ""
			                        ),
			                    "",
			                    CALCULATE( MIN( Org[Thứ tự] ) ), ASC 
			                ),
			                -- Chữ trống: MÀU TRẮNG
			                "<div style='color:white; font-style:italic; font-size:8px'>(Trống)</div>"
			            )
			
			        -- 3. Style cho khung chứa
			        VAR _Card_Style = 
			            "position: absolute; " & 
			            "top: " & _Top & "px; " & 
			            "left: " & _Left & "px; " & 
			            "width: 120px; " &             
			            "height: 90px; " &            
			            "font-size: 8px; " &           
			            "color: white; " &  -- Thiết lập màu trắng mặc định cho toàn bộ khung
			            
			            -- Căn chỉnh nội dung
			            "text-align: center; " &       
			            "white-space: normal; " &      
			            "word-wrap: break-word; " &    
			            "box-sizing: border-box; " &   
			            "padding: 3px; " &             
			            "display: flex; " &            
			            "flex-direction: column; " &   
			            "align-items: center; " &      
			            "justify-content: flex-start;" 
			
			        RETURN 
			            "<div style='" & _Card_Style & "'>" & 
			                _Content_HTML & 
			            "</div>"
			    )
			
			RETURN
			    -- Canvas Tổng
			    "<div style='position:relative; width:100%; height:90px; font-family: Segoe UI;'>" & 
			        _All_Cards & 
			    "</div>"
			```
		lineageTag: 6f71d1f1-1d27-4e8e-8bd0-bd61ef9a729b

	measure OrgChart_Support_Dept_Black = ```
			
			-- ==========================================================================================
			-- PHẦN 1: CẤU HÌNH DỊCH CHUYỂN
			-- ==========================================================================================
			VAR _Offset_X = -6  -- Số âm là dịch sang TRÁI
			
			-- ==========================================================================================
			-- PHẦN 2: BẢN ĐỒ TOẠ ĐỘ (Support Dept gốc)
			-- ==========================================================================================
			VAR _Layout_Map = DATATABLE (
			    "Ma_OC", STRING, "Left_PX", INTEGER, "Top_PX", INTEGER,
			    {
			        { "BCS",    3,    0 },
			        { "MPM",    142,  0 },
			        { "PRO",    278,  0 },
			        { "QSB1",   412,  0 },
			        { "SED1",   550,  0 },
			        { "IDD1",   686,  0 },
			        { "CSC",    822,  0 }
			    }
			)
			
			-- ==========================================================================================
			-- PHẦN 3: RENDER
			-- ==========================================================================================
			VAR _All_Cards = 
			    CONCATENATEX(
			        _Layout_Map,
			        VAR _Current_OC = [Ma_OC]
			        VAR _Left       = [Left_PX] + _Offset_X
			        VAR _Top        = [Top_PX]
			
			        -- A. Lấy bảng dữ liệu thuộc Mã OC hiện tại
			        VAR _OC_Data = 
			            CALCULATETABLE(
			                Org,
			                Org[Mã OC] = _Current_OC,
			                REMOVEFILTERS(Org)
			            )
			
			        -- B. KIỂM TRA TRẠNG THÁI "KHÔNG TỒN TẠI" CỦA CARD HIỆN TẠI
			        VAR _Is_Card_Disabled = CALCULATE( SUMX( Org, Org[Is_Khong_Ton_Tai] ), Org[Mã OC] = _Current_OC, REMOVEFILTERS(Org) ) > 0
			
			        -- 1. Lấy danh sách Chức danh duy nhất dưới dạng bảng ảo
			        VAR _Titles_In_OC = SUMMARIZE( _OC_Data, Org[Chức danh] )
			        VAR _Has_Data = NOT ISEMPTY(_Titles_In_OC)
			
			        -- 2. Tạo nội dung Text bên trong Card
			        VAR _Content_HTML = 
			            IF( 
			                _Has_Data,
			                CONCATENATEX(
			                    _Titles_In_OC, 
			                    VAR _Role = Org[Chức danh] -- Lấy trực tiếp từ bảng ảo _Titles_In_OC
			                    VAR _Names = 
			                        CALCULATE(
			                            CONCATENATEX(Org, Org[HTML_Nhan_Vien], "", Org[Thứ tự], ASC),
			                            Org[Chức danh] = _Role,
			                            Org[Mã OC] = _Current_OC,
			                            REMOVEFILTERS(Org)
			                        )
			                    
			                    -- Xác định màu chữ dựa vào trạng thái Card
			                    VAR _Text_Color = IF( _Is_Card_Disabled, "#777", "black" )
			                    
			                    RETURN 
			                        "<div style='margin-bottom:3px; width: 100%;'>" & 
			                            -- Tiêu đề Chức danh
			                            "<div style='color:" & _Text_Color & "; font-weight:600; font-size:10px; margin-bottom:2px; line-height:1.1;'>" & 
			                                _Role & 
			                            "</div>" & 
			                            -- Nội dung Nhân viên / Trống / Không tuyển
			                            "<div style='color:" & _Text_Color & "; font-size:10px; line-height:1.1;'>" &
			                                SWITCH(
			                                    TRUE(),
			                                    _Is_Card_Disabled, "<span style='font-style:italic;'></span>",
			                                    ISBLANK(_Names) || LEN(TRIM(_Names)) = 0, "<span style='font-style:italic; color:#999;'>(Trống)</span>",
			                                    _Names
			                                ) & 
			                            "</div>" & 
			                        "</div>",
			                    "",
			                    -- Sắp xếp bằng EARLIER chuẩn hóa
			                    CALCULATE( MIN( Org[Thứ tự] ), Org[Chức danh] = EARLIER(Org[Chức danh]), Org[Mã OC] = _Current_OC, REMOVEFILTERS(Org) ), ASC 
			                ),
			                -- Nếu hoàn toàn không có data dòng nào
			                "<div style='color:" & IF(_Is_Card_Disabled, "#777", "black") & "; font-style:italic; font-size:10px;'>" & 
			                    IF(_Is_Card_Disabled, "", "(Trống)") & 
			                "</div>"
			            )
			
			        -- 3. Style cho khung chứa (Bôi xám động)
			        VAR _Background_Style = 
			            IF( 
			                _Is_Card_Disabled, 
			                "background: #e6e6e6; color: #777; border-radius: 12px; border: 1px solid #ccc;", 
			                "background: transparent; color: black;" 
			            )
			
			        VAR _Card_Style = 
			            "position: absolute; " & 
			            "top: " & _Top & "px; " & 
			            "left: " & _Left & "px; " & 
			            "width: 130px; " & -- Giữ nguyên chiều rộng 130px theo layout gốc của measure này             
			            "height: 110px; " &            
			            "font-size: 10px; " & 
			            _Background_Style & " " & 
			            
			            "text-align: center; " &       
			            "white-space: normal; " &      
			            "word-wrap: break-word; " &    
			            "box-sizing: border-box; " &   
			            "padding: 5px 6px; " &             
			            "display: flex; " &            
			            "flex-direction: column; " &   
			            "align-items: center; " &      
			            "justify-content: flex-start;" 
			
			        RETURN 
			            "<div style='" & _Card_Style & "'>" & 
			                _Content_HTML & 
			            "</div>"
			    )
			
			RETURN
			    -- Canvas Tổng
			    "<div style='position:relative; width:100%; height:115px; font-family: Segoe UI;'>" & 
			        _All_Cards & 
			    "</div>"
			```
		lineageTag: 7287e5fa-af79-4244-a631-9d88ac5789e0

	measure OrgChart_Support_Dept_Black_1 = ```
			
			-- ==========================================================================================
			-- PHẦN 1: CẤU HÌNH DỊCH CHUYỂN
			-- ==========================================================================================
			VAR _Offset_X = -6  -- Số âm là dịch sang TRÁI
			
			-- ==========================================================================================
			-- PHẦN 2: BẢN ĐỒ TOẠ ĐỘ (Support Dept 1)
			-- ==========================================================================================
			VAR _Layout_Map = DATATABLE (
			    "Ma_OC", STRING, "Left_PX", INTEGER, "Top_PX", INTEGER,
			    {
			        { "OCS",    0,    0 },
			        { "DCM",    138,  0 },
			        { "BMD",    272,  0 },
			        { "QSB2",   410,  0 },
			        { "SED2",   546,  0 },
			        { "IDD2",   682,  0 }
			    }
			)
			
			-- ==========================================================================================
			-- PHẦN 3: RENDER
			-- ==========================================================================================
			VAR _All_Cards = 
			    CONCATENATEX(
			        _Layout_Map,
			        VAR _Current_OC = [Ma_OC]
			        VAR _Left       = [Left_PX] + _Offset_X
			        VAR _Top        = [Top_PX]
			
			        -- A. Lấy bảng dữ liệu thuộc Mã OC hiện tại
			        VAR _OC_Data = 
			            CALCULATETABLE(
			                Org,
			                Org[Mã OC] = _Current_OC,
			                REMOVEFILTERS(Org)
			            )
			
			        -- B. KIỂM TRA TRẠNG THÁI "KHÔNG TỒN TẠI" CỦA CARD HIỆN TẠI
			        VAR _Is_Card_Disabled = CALCULATE( SUMX( Org, Org[Is_Khong_Ton_Tai] ), Org[Mã OC] = _Current_OC, REMOVEFILTERS(Org) ) > 0
			
			        -- 1. Lấy danh sách Chức danh duy nhất dưới dạng bảng ảo
			        VAR _Titles_In_OC = SUMMARIZE( _OC_Data, Org[Chức danh] )
			        VAR _Has_Data = NOT ISEMPTY(_Titles_In_OC)
			
			        -- 2. Tạo nội dung Text bên trong Card
			        VAR _Content_HTML = 
			            IF( 
			                _Has_Data,
			                CONCATENATEX(
			                    _Titles_In_OC, 
			                    VAR _Role = Org[Chức danh] -- Lấy trực tiếp từ bảng ảo _Titles_In_OC
			                    VAR _Names = 
			                        CALCULATE(
			                            CONCATENATEX(Org, Org[HTML_Nhan_Vien], "", Org[Thứ tự], ASC),
			                            Org[Chức danh] = _Role,
			                            Org[Mã OC] = _Current_OC,
			                            REMOVEFILTERS(Org)
			                        )
			                    
			                    -- Xác định màu chữ dựa vào trạng thái Card
			                    VAR _Text_Color = IF( _Is_Card_Disabled, "#777", "black" )
			                    
			                    RETURN 
			                        "<div style='margin-bottom:3px; width: 100%;'>" & 
			                            -- Tiêu đề Chức danh
			                            "<div style='color:" & _Text_Color & "; font-weight:600; font-size:10px; margin-bottom:2px; line-height:1.1;'>" & 
			                                _Role & 
			                            "</div>" & 
			                            -- Nội dung Nhân viên / Trống / Không tuyển
			                            "<div style='color:" & _Text_Color & "; font-size:10px; line-height:1.1;'>" &
			                                SWITCH(
			                                    TRUE(),
			                                    _Is_Card_Disabled, "<span style='font-style:italic;'></span>",
			                                    ISBLANK(_Names) || LEN(TRIM(_Names)) = 0, "<span style='font-style:italic; color:#999;'>(Trống)</span>",
			                                    _Names
			                                ) & 
			                            "</div>" & 
			                        "</div>",
			                    "",
			                    -- Sắp xếp chuẩn hóa bằng EARLIER không lo lỗi cột Chức danh
			                    CALCULATE( MIN( Org[Thứ tự] ), Org[Chức danh] = EARLIER(Org[Chức danh]), Org[Mã OC] = _Current_OC, REMOVEFILTERS(Org) ), ASC 
			                ),
			                -- Nếu hoàn toàn không có data dòng nào
			                "<div style='color:" & IF(_Is_Card_Disabled, "#777", "black") & "; font-style:italic; font-size:10px;'>" & 
			                    IF(_Is_Card_Disabled, "Không tuyển", "(Trống)") & 
			                "</div>"
			            )
			
			        -- 3. Style cho khung chứa (Bôi xám động)
			        VAR _Background_Style = 
			            IF( 
			                _Is_Card_Disabled, 
			                "background: #e6e6e6; color: #777; border-radius: 12px; border: 1px solid #ccc;", 
			                "background: transparent; color: black;" 
			            )
			
			        VAR _Card_Style = 
			            "position: absolute; " & 
			            "top: " & _Top & "px; " & 
			            "left: " & _Left & "px; " & 
			            "width: 133px; " &              
			            "height: 110px; " &            
			            "font-size: 10px; " & 
			            _Background_Style & " " & 
			            
			            "text-align: center; " &       
			            "white-space: normal; " &      
			            "word-wrap: break-word; " &    
			            "box-sizing: border-box; " &   
			            "padding: 5px 6px; " &             
			            "display: flex; " &            
			            "flex-direction: column; " &   
			            "align-items: center; " &      
			            "justify-content: flex-start;" 
			
			        RETURN 
			            "<div style='" & _Card_Style & "'>" & 
			                _Content_HTML & 
			            "</div>"
			    )
			
			RETURN
			    -- Canvas Tổng
			    "<div style='position:relative; width:100%; height:115px; font-family: Segoe UI;'>" & 
			        _All_Cards & 
			    "</div>"
			```
