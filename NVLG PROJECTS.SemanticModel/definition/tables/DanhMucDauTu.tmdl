	column HTML_Card_Drillthrough = ```
			
			-- 1. INPUT: Lấy trực tiếp giá trị của dòng hiện tại (Bỏ SELECTEDVALUE và MAX)
			VAR _Line1_TieuDe  = "BAN ĐIỀU HÀNH DỰ ÁN VÙNG"
			VAR _Line2_KhuVuc  = 'DanhMucDauTu'[BanDieuHanh]
			VAR _Line3_ChucVu  = ""
			VAR _Line4_TenNV   =  ""
			
			-- 2. XỬ LÝ TEXT: Giữ nguyên logic
			VAR _Line2_Clean = UPPER(TRIM(SUBSTITUTE(_Line2_KhuVuc, "Ban điều hành Dự án Vùng", "")))
			
			-- 3. TRẢ VỀ HTML: Giữ nguyên logic hiển thị
			RETURN
			    "<div style='text-align: center; font-family: Segoe UI, sans-serif; color: #003366;'>" & 
			        
			        -- Dòng 1
			        "<div style='font-size: 12px; margin-bottom: 2px; font-weight: bold;'>" & 
			            _Line1_TieuDe & 
			        "</div>" &
			
			        -- Dòng 2
			        "<div style='font-size: 12px; font-weight: 900; margin-bottom: 4px; text-transform: uppercase;'>" & 
			            _Line2_Clean & 
			        "</div>" &
			
			        -- Dòng 3
			        "<div style='font-size: 12px; margin-bottom: 2px; font-weight: bold'>" & 
			            _Line3_ChucVu & 
			        "</div>" &
			
			        -- Dòng 4
			        "<div style='font-size: 12px; '>" & 
			            _Line4_TenNV & 
			        "</div>" &
			
			    "</div>"
			```
		lineageTag: e51ad369-c55c-487e-b053-0b26273c9a09
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column HTML_Card_Drillthrough_2 = ```
			
			-- 1. INPUT: Lấy trực tiếp giá trị của dòng hiện tại (Bỏ SELECTEDVALUE và MAX)
			VAR _Line1_TieuDe  = "BAN ĐIỀU HÀNH DỰ ÁN KHU VỰC"
			VAR _Line2_KhuVuc  = 'DanhMucDauTu'[BanDieuHanh]
			VAR _Line3_ChucVu  = "Giám Đốc Ban Điều Hành Dự Án (GMD-NVLG)"
			VAR _Line4_TenNV   = 'DanhMucDauTu'[Quản Lý Khu Vực]
			
			-- 2. XỬ LÝ TEXT: Giữ nguyên logic
			VAR _Line2_Clean = UPPER(TRIM(SUBSTITUTE(_Line2_KhuVuc, "Khu vực", "")))
			
			-- 3. TRẢ VỀ HTML: Giữ nguyên logic hiển thị
			RETURN
			    "<div style='text-align: center; font-family: Segoe UI, sans-serif; color: #003366;'>" & 
			        
			        -- Dòng 1
			        "<div style='font-size: 16px; margin-bottom: 2px; font-weight: bold;'>" & 
			            _Line1_TieuDe & 
			        "</div>" &
			
			        -- Dòng 2
			        "<div style='font-size: 16px; font-weight: 900; margin-bottom: 4px; text-transform: uppercase;'>" & 
			            _Line2_Clean & 
			        "</div>" &
			
			        -- Dòng 3
			        "<div style='font-size: 16px; margin-bottom: 2px; font-weight: bold'>" & 
			            _Line3_ChucVu & 
			        "</div>" &
			
			        -- Dòng 4
			        "<div style='font-size: 16px; '>" & 
			            _Line4_TenNV & 
			        "</div>" &
			
			    "</div>"
			```
		lineageTag: 25414f36-8a2c-4a1b-bb48-c26d41b3bfee
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column TenDuAn_CoSTT = ```
			
			// 1. Lấy thông tin của dòng hiện tại
			VAR TenHienTai = 'DanhMucDauTu'[Tên Dự Án]
			VAR BanHienTai = 'DanhMucDauTu'[BanDieuHanh]
			VAR HienTrangHienTai = 'DanhMucDauTu'[Hiện trạng đầu tư]
			
			// 2. TẠO TRỌNG SỐ CHO DÒNG HIỆN TẠI (Để so sánh)
			VAR DiemHienTai = 
			    SWITCH(
			        TRUE(),
			        TenHienTai = "1800 HA TÂY NAM", "001",
			        TenHienTai = "DỰ ÁN GÒ GĂNG", "002",
			        TenHienTai = "TRƯỜNG ĐUA CHÓ 4HA", "003",
			        TenHienTai = "TDỰ ÁN GOLD COAST VŨNG TÀU", "004",
			        TenHienTai = "KHU ĐÔ THỊ NGHĨ DƯỠNG PARADISEVUNG TAU","005",
			        "100_" & TenHienTai -- 
			    )
			
			
			VAR SoThuTu = RANKX(
			    FILTER(
			        ALL('DanhMucDauTu'), 
			        'DanhMucDauTu'[BanDieuHanh] = BanHienTai && 
			        'DanhMucDauTu'[Hiện trạng đầu tư] = HienTrangHienTai
			    ), 
			    VAR _TenLoop = 'DanhMucDauTu'[Tên Dự Án]
			    RETURN 
			        SWITCH(
			            TRUE(),
			            _TenLoop = "1800 HA TÂY NAM", "001",
			            _TenLoop = "DỰ ÁN GÒ GĂNG", "002",
			            _TenLoop = "TRƯỜNG ĐUA CHÓ 4HA", "003",
			            _TenLoop = "TDỰ ÁN GOLD COAST VŨNG TÀU", "004",
			            _TenLoop = "KHU ĐÔ THỊ NGHĨ DƯỠNG PARADISEVUNG TAU","005",
			            "100_" & _TenLoop
			        ), 
			    DiemHienTai, 
			    ASC, 
			    DENSE
			)
			
			
			RETURN RIGHT("0" & SoThuTu, 2) & ". " & TenHienTai
			```
		lineageTag: aa71513b-a763-49d3-9916-6b587a795ddc
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

