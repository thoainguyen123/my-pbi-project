table DanhMucDauTu
	lineageTag: 80e7976e-a067-4c1c-9f89-6cc6f516b628

	measure 'Khu vực format' = FIRSTNONBLANK(DanhMucDauTu[BanDieuHanh])
		lineageTag: bfc9318b-e1e4-4abf-9fa9-2e59f661be5b

	measure 'SL Vùng' =
			
			var x = CALCULATE(DISTINCTCOUNTNOBLANK(DanhMucDauTu[Ten Vung]),Org[Mã OC] <> BLANK())
			RETURN "Tổng Vùng : "&x
		lineageTag: 22cad853-864c-4f2a-afc8-6ed247e2ebbe

	measure 'Quy mô' = ```
			
			VAR MaxScale = MAX(DanhMucDauTu[scale])
			RETURN "Quy mô : " & IF(ISBLANK(MaxScale), "0", FORMAT(MaxScale, "#,0")) & " (m²)" & ", Số lượng sản phẩm : " 
			```
		lineageTag: e656be47-0e69-42b7-873b-fde0fbc51a14

	measure 'Tên dự án scope' =
			
			VAR Project  = MAX(DanhMucDauTu[Tên Dự Án])
			RETURN "Tên pháp lý : " & Project
		lineageTag: d0ce0ff1-11ef-4e2c-b2ea-1b6fe4ba3488

	measure 'Địa chỉ scope' =
			
			VAR Project  = MAX(DanhMucDauTu[address])
			RETURN "Địa điểm : " & Project
		lineageTag: b7748168-5e56-4d26-b9c1-338dd1bc43ea

	measure 'Mã dự án' =
			
			VAR Project  = MAX(DanhMucDauTu[Link dự án])
			RETURN "Mã dự án : " & Project
		lineageTag: 3b1e55d2-0113-4a6f-ae1f-da78de6e0a89

	measure 'Tên dự án scope thương mại' =
			
			VAR Project  = MAX(DanhMucDauTu[Tên Dự Án])
			RETURN "Tên thương mại : " & Project
		lineageTag: 14c6121b-2eec-4821-ae3c-06bdd37af0cd

	measure 'chủ đầu tư scope' =
			
			VAR Project  = MAX(DanhMucDauTu[project_owner])
			RETURN "Chủ đầu tư : " & Project
		lineageTag: 6b015d60-964d-4641-b967-7578d9efc074

	measure Nguon_goc =
			
			VAR MaxScale = MAX(Project[desc])
			RETURN MaxScale
		lineageTag: 2104d52b-613d-491d-8387-3fab3c331e34

